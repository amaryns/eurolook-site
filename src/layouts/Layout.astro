---
// Layout.astro — Eurolook Construction
// Navigation + Footer partagés sur toutes les pages
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}
const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/images/og-eurolook.jpg'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0C0B09" />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="Eurolook Construction" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicons/favicon.ico" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicons/favicon-48x48.png" />
  <link rel="icon" type="image/png" sizes="96x96" href="/favicons/favicon-96x96.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
  <link rel="manifest" href="/favicons/site.webmanifest" />
  <meta name="theme-color" content="#1A2B47" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- ════════════════════════════════════════════════════════════════
       Google Analytics 4 avec Consent Mode v2
       Conformité RGPD/CNIL : par défaut TOUT EST REFUSÉ.
       L'utilisateur autorise via la bannière cookies (footer).
  ══════════════════════════════════════════════════════════════════ -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}

    // 1. Définir les défauts AVANT le chargement de GA (= tout refusé)
    gtag('consent', 'default', {
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'analytics_storage': 'denied',
      'functionality_storage': 'denied',
      'personalization_storage': 'denied',
      'security_storage': 'granted',
      'wait_for_update': 500
    });

    // 2. Mettre à jour selon le choix précédent de l'utilisateur (si déjà choisi)
    try {
      var savedConsent = localStorage.getItem('eurolook_cookie_consent');
      if (savedConsent === 'accepted') {
        gtag('consent', 'update', {
          'analytics_storage': 'granted',
          'functionality_storage': 'granted'
        });
      }
    } catch(e) {}

    // 3. Charger Google Analytics
    gtag('js', new Date());
    gtag('config', 'G-PHKC7CVB06', {
      'anonymize_ip': true
    });
  </script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-PHKC7CVB06"></script>
  <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "GeneralContractor",
    "name": "Eurolook Construction",
    "legalName": "Euro Look",
    "alternateName": "Eurolook",
    "url": "https://eurolookgroupe.com",
    "logo": "https://eurolookgroupe.com/logos/logo.svg",
    "image": "https://eurolookgroupe.com/logos/logo.svg",
    "description": "Spécialiste du renforcement structurel et de l'aménagement de cellules commerciales en site occupé. Partenaire des grandes enseignes nationales depuis 2015.",
    "foundingDate": "2015-01-02",
    "telephone": "+33983039959",
    "email": "contact@eurolookgroupe.com",
    "vatID": "FR38808762470",
    "taxID": "808762470",
    "address": [
      {
        "@type": "PostalAddress",
        "name": "Siège social",
        "streetAddress": "50 avenue des Champs Élysées",
        "addressLocality": "Paris",
        "postalCode": "75008",
        "addressCountry": "FR"
      },
      {
        "@type": "PostalAddress",
        "name": "Établissement opérationnel",
        "streetAddress": "309 Rue Louis Lépine, ZAC des Chabauds",
        "addressLocality": "Bouc-Bel-Air",
        "postalCode": "13320",
        "addressCountry": "FR"
      }
    ],
    "areaServed": {
      "@type": "Country",
      "name": "France"
    },
    "knowsAbout": [
      "Renforcement structurel",
      "Réhabilitation technique",
      "Conception et aménagement de points de vente",
      "Menuiserie et aluminium",
      "Pilotage et coordination de chantier (OPC)",
      "Aménagements tertiaires et finitions"
    ],
    "founder": {
      "@type": "Person",
      "name": "Mehdi Belkir Guemari",
      "jobTitle": "Gérant"
    },
    "sameAs": []
  }
  </script>
</head>
<body>

  <!-- Lien d'évitement accessibilité -->
  <a class="skip-link" href="#main">Aller au contenu principal</a>

  <!-- ════ NAVIGATION ════ -->
  <header>
    <nav class="site-nav" role="navigation" aria-label="Navigation principale">
      <div class="nav-inner">

        <!-- Logo -->
        <a class="nav-logo" href="/" aria-label="Eurolook Construction — Accueil">
          <img
            src="/logos/logo.svg"
            alt="Eurolook Construction"
            width="200"
            height="48"
            loading="eager"
          />
        </a>

        <!-- Liens desktop -->
        <ul class="nav-links" role="list">
          <li><a class="nav-link" href="/">Accueil</a></li>
          <li><a class="nav-link" href="/entreprise">L'entreprise</a></li>
          <li class="nav-item has-drop">
            <a class="nav-link" href="/expertises" aria-haspopup="true" aria-expanded="false" id="exp-trigger">
              Expertises<span class="nav-arrow" aria-hidden="true">▾</span>
            </a>
            <div class="dropdown" role="region" aria-labelledby="exp-trigger">
              <a class="drop-item" href="/expertises/renforcement-structurel">
                <span class="drop-ic" aria-hidden="true">🏗</span>
                <span>
                  <span class="drop-strong">Renforcement structurel</span>
                  <span class="drop-sub">Reprise en sous-œuvre, micropieux</span>
                </span>
              </a>
              <a class="drop-item" href="/expertises/rehabilitation-technique">
                <span class="drop-ic" aria-hidden="true">🔧</span>
                <span>
                  <span class="drop-strong">Réhabilitation technique</span>
                  <span class="drop-sub">Site occupé, nuit et week-end</span>
                </span>
              </a>
              <a class="drop-item" href="/expertises/conception-amenagement-points-de-vente">
                <span class="drop-ic" aria-hidden="true">🏪</span>
                <span>
                  <span class="drop-strong">Conception & aménagement de points de vente</span>
                  <span class="drop-sub">Multi-sites, enseignes nationales</span>
                </span>
              </a>
              <a class="drop-item" href="/expertises/menuiserie-et-aluminium">
                <span class="drop-ic" aria-hidden="true">🪟</span>
                <span>
                  <span class="drop-strong">Menuiserie et aluminium</span>
                  <span class="drop-sub">Atelier La Fabrique intégré</span>
                </span>
              </a>
              <a class="drop-item" href="/expertises/pilotage-coordination-chantier-opc">
                <span class="drop-ic" aria-hidden="true">⚙</span>
                <span>
                  <span class="drop-strong">Pilotage & coordination de chantier (OPC)</span>
                  <span class="drop-sub">Pilotage MOE/MOA, plans d'exécution</span>
                </span>
              </a>
              <a class="drop-item" href="/expertises/amenagements-tertiaires-finitions">
                <span class="drop-ic" aria-hidden="true">🏢</span>
                <span>
                  <span class="drop-strong">Aménagements tertiaires & finitions</span>
                  <span class="drop-sub">Tertiaire et commercial haut de gamme</span>
                </span>
              </a>
              <a class="drop-footer" href="/expertises">Toutes nos expertises →</a>
            </div>
          </li>
          <li><a class="nav-link" href="/realisations">Réalisations</a></li>
          <li><a class="nav-link" href="/la-fabrique">La Fabrique</a></li>
          <li><a class="nav-link" href="/contact">Contact</a></li>
        </ul>

        <!-- CTA desktop -->
        <a class="nav-cta btn btn-gold btn-sm" href="/contact" aria-label="Demander un devis gratuit">
          Devis gratuit
        </a>

        <!-- Burger mobile -->
        <button
          class="burger"
          id="burger"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
          aria-controls="mob"
        >
          <span class="b-bar" aria-hidden="true"></span>
          <span class="b-bar" aria-hidden="true"></span>
          <span class="b-bar" aria-hidden="true"></span>
        </button>

      </div>
    </nav>

    <!-- Menu mobile -->
    <nav class="mobile-nav" id="mob" role="dialog" aria-modal="true" aria-label="Menu principal">
      <ul class="mob-list" role="list">
        <li><a class="mob-link" href="/">Accueil</a></li>
        <li><a class="mob-link" href="/entreprise">L'entreprise</a></li>
        <li>
          <button
            class="mob-exp-btn"
            id="mob-exp-toggle"
            aria-expanded="false"
            aria-controls="mob-exp-list"
          >
            Expertises<span class="mob-exp-arrow" aria-hidden="true">▾</span>
          </button>
          <div id="mob-exp-list" class="mob-exp-list" role="list">
            <a class="mob-exp-item" href="/expertises/renforcement-structurel">Renforcement structurel</a>
            <a class="mob-exp-item" href="/expertises/rehabilitation-technique">Réhabilitation technique</a>
            <a class="mob-exp-item" href="/expertises/conception-amenagement-points-de-vente">Conception & aménagement de points de vente</a>
            <a class="mob-exp-item" href="/expertises/menuiserie-et-aluminium">Menuiserie et aluminium</a>
            <a class="mob-exp-item" href="/expertises/pilotage-coordination-chantier-opc">Pilotage & coordination de chantier (OPC)</a>
            <a class="mob-exp-item" href="/expertises/amenagements-tertiaires-finitions">Aménagements tertiaires & finitions</a>
          </div>
        </li>
        <li><a class="mob-link" href="/realisations">Réalisations</a></li>
        <li><a class="mob-link" href="/la-fabrique">La Fabrique</a></li>
        <li><a class="mob-link" href="/contact">Contact</a></li>
      </ul>
      <a class="mob-cta" href="/contact">Devis gratuit</a>
    </nav>
  </header>

  <!-- ════ CONTENU DE LA PAGE ════ -->
  <main id="main">
    <slot />
  </main>

  <!-- ════ FOOTER ════ -->
  <footer class="site-footer" role="contentinfo">
    <div class="footer-inner">
      <a class="footer-logo" href="/" aria-label="Eurolook Construction">
        <img
          src="/logos/logo.svg"
          alt="Eurolook Construction"
          width="150"
          height="42"
          loading="lazy"
        />
      </a>
      <nav class="footer-links" aria-label="Liens légaux">
        <a href="/mentions-legales">Mentions légales</a>
        <a href="/confidentialite">Confidentialité</a>
        <a href="#" data-cookie-manage>Gérer mes cookies</a>
        <a href="/plan-du-site">Plan du site</a>
        <a href="/contact" style="color:var(--gold);font-weight:600;">Demander un devis</a>
      </nav>
      <p class="footer-copy">© 2026 Eurolook Construction — SIRET&nbsp;808&nbsp;762&nbsp;470&nbsp;000&nbsp;58</p>
    </div>
  </footer>

  <!-- ════ BANNIÈRE COOKIES (RGPD/CNIL) ════ -->
  <div id="cookie-banner" class="cookie-banner" hidden role="dialog" aria-modal="false" aria-labelledby="cookie-banner-title" aria-describedby="cookie-banner-desc">
    <div class="cookie-banner-inner">
      <div class="cookie-banner-text">
        <h2 id="cookie-banner-title" class="cookie-banner-title">Cookies & confidentialité</h2>
        <p id="cookie-banner-desc" class="cookie-banner-desc">
          Nous utilisons des cookies pour mesurer l'audience de notre site et améliorer votre expérience. Aucune donnée personnelle n'est collectée sans votre accord.
        </p>
      </div>
      <div class="cookie-banner-actions">
        <button type="button" class="cookie-btn cookie-btn-refuse" id="cookie-refuse">Refuser</button>
        <button type="button" class="cookie-btn cookie-btn-accept" id="cookie-accept">Accepter</button>
      </div>
      <a href="/confidentialite" class="cookie-banner-link">En savoir plus</a>
    </div>
  </div>

  <!-- ════ JAVASCRIPT ════ -->
  <script>
  (function(){
    'use strict';

    /* ── BURGER ── */
    var burger = document.getElementById('burger');
    var mob = document.getElementById('mob');
    if(burger && mob){
      burger.addEventListener('click', function(){
        var o = mob.classList.contains('is-open');
        mob.classList.toggle('is-open', !o);
        burger.setAttribute('aria-expanded', String(!o));
        document.body.classList.toggle('menu-open', !o);
      });
      mob.querySelectorAll('a').forEach(function(el){
        el.addEventListener('click', function(){
          mob.classList.remove('is-open');
          burger.setAttribute('aria-expanded', 'false');
          document.body.classList.remove('menu-open');
        });
      });
      document.addEventListener('keydown', function(e){
        if(e.key === 'Escape' && mob.classList.contains('is-open')){
          mob.classList.remove('is-open');
          burger.setAttribute('aria-expanded', 'false');
          document.body.classList.remove('menu-open');
          burger.focus();
        }
      });
    }

    /* ── DROPDOWN DESKTOP ── */
    document.querySelectorAll('.has-drop').forEach(function(item){
      var link = item.querySelector('.nav-link'), t;
      function open(){
        clearTimeout(t);
        document.querySelectorAll('.has-drop').forEach(function(d){
          if(d !== item) d.classList.remove('drop-open');
        });
        item.classList.add('drop-open');
        if(link) link.setAttribute('aria-expanded', 'true');
      }
      function close(){
        t = setTimeout(function(){
          item.classList.remove('drop-open');
          if(link) link.setAttribute('aria-expanded', 'false');
        }, 130);
      }
      item.addEventListener('mouseenter', open);
      item.addEventListener('mouseleave', close);
      item.addEventListener('focusin', function(){ clearTimeout(t); open(); });
      item.addEventListener('focusout', function(){
        t = setTimeout(function(){
          if(!item.contains(document.activeElement)) close();
        }, 100);
      });
    });
    document.addEventListener('click', function(e){
      document.querySelectorAll('.has-drop').forEach(function(d){
        if(!d.contains(e.target)) d.classList.remove('drop-open');
      });
    });

    /* ── ACCORDION EXPERTISES MOBILE ── */
    var mbt = document.getElementById('mob-exp-toggle');
    var mbl = document.getElementById('mob-exp-list');
    if(mbt && mbl){
      mbt.addEventListener('click', function(){
        var o = mbl.classList.contains('is-open');
        mbl.classList.toggle('is-open', !o);
        mbt.setAttribute('aria-expanded', String(!o));
      });
    }

    /* ── BANNIÈRE COOKIES (RGPD + Consent Mode v2) ── */
    (function(){
      var banner = document.getElementById('cookie-banner');
      if(!banner) return;

      var STORAGE_KEY = 'eurolook_cookie_consent';
      var savedConsent = null;
      try { savedConsent = localStorage.getItem(STORAGE_KEY); } catch(e) {}

      // Afficher la bannière si pas encore choisi
      if(!savedConsent){
        banner.hidden = false;
      }

      function setConsent(value){
        try { localStorage.setItem(STORAGE_KEY, value); } catch(e) {}
        banner.hidden = true;
        if(typeof gtag === 'function'){
          if(value === 'accepted'){
            gtag('consent', 'update', {
              'analytics_storage': 'granted',
              'functionality_storage': 'granted'
            });
          } else {
            gtag('consent', 'update', {
              'analytics_storage': 'denied',
              'functionality_storage': 'denied'
            });
          }
        }
      }

      var acceptBtn = document.getElementById('cookie-accept');
      var refuseBtn = document.getElementById('cookie-refuse');
      if(acceptBtn) acceptBtn.addEventListener('click', function(){ setConsent('accepted'); });
      if(refuseBtn) refuseBtn.addEventListener('click', function(){ setConsent('refused'); });

      // Permettre de rouvrir la bannière depuis un lien dans le footer
      var manageLinks = document.querySelectorAll('[data-cookie-manage]');
      manageLinks.forEach(function(link){
        link.addEventListener('click', function(e){
          e.preventDefault();
          try { localStorage.removeItem(STORAGE_KEY); } catch(e) {}
          banner.hidden = false;
          banner.focus();
        });
      });
    })();

  })();

  /* ── REVEAL ON SCROLL (système global) ── */
  (function(){
    if(!('IntersectionObserver' in window)){
      document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-scale,.stagger').forEach(function(el){
        el.classList.add('is-visible');
      });
      return;
    }
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if(entry.isIntersecting){
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    },{threshold:.15,rootMargin:'0px 0px -80px 0px'});
    document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-scale,.stagger').forEach(function(el){
      io.observe(el);
    });
  })();

  /* ── ONGLETS EXPERTISES ── */
  (function(){
    var btns = document.querySelectorAll('.exp-tab-btn');
    var panels = document.querySelectorAll('.exp-panel');
    if(!btns.length) return;
    function activateTab(key){
      btns.forEach(function(b){
        var a = b.dataset.tab === key;
        b.classList.toggle('is-active', a);
        b.setAttribute('aria-selected', String(a));
      });
      panels.forEach(function(p){
        var a = p.id === 'panel-' + key;
        if(a){
          p.style.display = 'grid';
          requestAnimationFrame(function(){
            requestAnimationFrame(function(){ p.classList.add('is-active'); });
          });
        } else {
          p.classList.remove('is-active');
          p.style.display = 'none';
        }
      });
    }
    btns.forEach(function(btn){
      btn.addEventListener('click', function(){ activateTab(this.dataset.tab); });
      btn.addEventListener('keydown', function(e){
        var list = Array.from(btns), idx = list.indexOf(this);
        if(e.key === 'ArrowDown' || e.key === 'ArrowRight'){
          e.preventDefault(); list[(idx+1) % list.length].focus();
        }
        if(e.key === 'ArrowUp' || e.key === 'ArrowLeft'){
          e.preventDefault(); list[(idx-1+list.length) % list.length].focus();
        }
      });
    });
  })();

  /* ── COUNTUP STATS ── */
  (function(){
    var done = false;
    var ss = document.querySelector('.stats-band');
    if(ss && 'IntersectionObserver' in window){
      new IntersectionObserver(function(entries){
        if(entries[0].isIntersecting && !done){
          done = true;
          document.querySelectorAll('[data-count]').forEach(function(el){
            var t = parseInt(el.dataset.count);
            var s = el.dataset.suffix || '';
            var st = null, d = 1500;
            function f(ts){
              if(!st) st = ts;
              var p = Math.min((ts-st)/d, 1);
              var e = 1 - Math.pow(1-p, 3);
              el.textContent = Math.floor(e*t) + s;
              if(p < 1) requestAnimationFrame(f);
            }
            requestAnimationFrame(f);
          });
        }
      }, {threshold: 0.4}).observe(ss);
    }
  })();

  /* ── CARROUSEL LOGOS (optimisé : pause hors viewport + onglet inactif) ── */
  (function(){
    var track = document.querySelector('.carousel-track');
    if(!track) return;
    track.querySelectorAll('.c-item').forEach(function(item){
      track.appendChild(item.cloneNode(true));
    });
    var pos = 0, speed = 0.55, paused = false, inView = true, tabVisible = true;
    var wrap = document.querySelector('.carousel-inner');
    track.style.willChange = 'transform';

    function loop(){
      if(!paused && inView && tabVisible){
        pos -= speed;
        var hw = track.scrollWidth / 2;
        if(Math.abs(pos) >= hw) pos = 0;
        track.style.transform = 'translateX(' + pos + 'px)';
      }
      requestAnimationFrame(loop);
    }
    requestAnimationFrame(loop);

    // Pause quand carrousel hors viewport
    if('IntersectionObserver' in window && wrap){
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){ inView = e.isIntersecting; });
      },{threshold:0.05});
      io.observe(wrap);
    }
    // Pause quand onglet inactif
    document.addEventListener('visibilitychange', function(){
      tabVisible = !document.hidden;
    });

    if(wrap){
      wrap.addEventListener('mouseenter', function(){ paused = true; });
      wrap.addEventListener('mouseleave', function(){ paused = false; });
      wrap.addEventListener('touchstart', function(){ paused = true; }, {passive: true});
      wrap.addEventListener('touchend', function(){
        setTimeout(function(){ paused = false; }, 1500);
      }, {passive: true});
    }
  })();

  /* ── FILTRES RÉALISATIONS ── */
  (function(){
    document.querySelectorAll('.filter-btn').forEach(function(btn){
      btn.addEventListener('click', function(){
        document.querySelectorAll('.filter-btn').forEach(function(b){
          b.classList.remove('is-active');
          b.setAttribute('aria-pressed', 'false');
        });
        this.classList.add('is-active');
        this.setAttribute('aria-pressed', 'true');
        var cat = this.dataset.cat;
        document.querySelectorAll('.proj-full-card, .proj-card').forEach(function(card){
          card.hidden = !(!cat || card.dataset.cat === cat);
        });
      });
    });
  })();
  </script>

</body>
</html>
