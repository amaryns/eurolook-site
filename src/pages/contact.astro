---
// src/pages/contact.astro
// Page Contact — VERSION 2.0
// Refonte esthétique + corrections factuelles (pas de "48h", pas de "interlocuteur unique")

import Layout from '../layouts/Layout.astro';
const FORMSPREE_URL = "https://formspree.io/f/xbdbljey";
---

<Layout
  title="Contact & Devis — Eurolook Construction"
  description="Contactez Eurolook Construction pour votre projet de renforcement structurel, réhabilitation technique ou aménagement de points de vente. Paris & Bouc-Bel-Air."
  canonical="https://eurolookgroupe.com/contact"
>

  <!-- ████ EN-TÊTE (pas de hero) ████ -->
  <section class="contact-header reveal">
    <div class="contact-header-inner">
      <nav aria-label="Fil d'Ariane">
        <p class="page-breadcrumb">
          <a href="/">Accueil</a>
          <span aria-hidden="true">→</span>
          <span>Contact</span>
        </p>
      </nav>

      <span class="hero-eyebrow">
        <span class="dot" aria-hidden="true"></span>
        Parlons de votre projet
      </span>

      <h1 class="contact-h1">
        DEMANDER<br/><em>UN DEVIS.</em>
      </h1>
      <p class="contact-lead">
        Notre équipe vous répond rapidement.
        Renforcement structurel, réhabilitation, aménagement — confiez-nous votre projet.
      </p>
    </div>
  </section>

  <!-- ████ CARTES INFOS — Téléphone / Email / Adresse ████ -->
  <section class="contact-cards-band" aria-label="Coordonnées">
    <div class="contact-cards-inner stagger">

      <a href="tel:0983039959" class="contact-card">
        <div class="contact-card-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="contact-card-label">Téléphone</span>
        <strong class="contact-card-value">09 83 03 99 59</strong>
        <span class="contact-card-meta">Appeler maintenant</span>
      </a>

      <a href="mailto:contact@eurolookgroupe.com" class="contact-card">
        <div class="contact-card-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="contact-card-label">Email</span>
        <strong class="contact-card-value contact-card-value-sm">contact@<wbr/>eurolookgroupe.com</strong>
        <span class="contact-card-meta">Écrire un message</span>
      </a>

      <a href="https://maps.google.com/?q=309+Rue+Louis+Lépine+13320+Bouc-Bel-Air" target="_blank" rel="noopener" class="contact-card">
        <div class="contact-card-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="contact-card-label">Adresse</span>
        <strong class="contact-card-value contact-card-value-sm">309 Rue Louis Lépine<br/>13320 Bouc-Bel-Air</strong>
        <span class="contact-card-meta">Voir sur la carte</span>
      </a>

    </div>
  </section>

  <!-- ████ FORMULAIRE — Light break crème ████ -->
  <section class="contact-form-section" aria-labelledby="form-h2">
    <div class="contact-form-inner">

      <div class="contact-form-head reveal">
        <span class="s-tag">Formulaire de contact</span>
        <h2 id="form-h2" class="about-title">
          DÉCRIVEZ<br/><em>VOTRE PROJET.</em>
        </h2>
        <p>
          Plus votre description est détaillée, plus notre réponse sera précise.
          Localisation, superficie, contraintes, délais — toutes les informations comptent.
        </p>
      </div>

      <div class="contact-form-wrap-v2 reveal">

        <!-- Message de succès -->
        <div id="form-success" class="form-success" hidden role="alert" aria-live="polite">
          <span class="form-success-icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8 12.5L11 15.5L16 9.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <h2>Message envoyé</h2>
          <p>Notre équipe vous répondra rapidement.</p>
          <a class="btn btn-dark" href="/" style="margin-top:1.5rem;">Retour à l'accueil</a>
        </div>

        <form id="contact-form" class="form-v2" novalidate aria-label="Formulaire de demande de devis">
          <input type="text" name="_gotcha" style="display:none;" />

          <div id="form-error" class="form-v2-error-global" hidden role="alert">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
              <line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2"/>
              <circle cx="12" cy="16" r="1" fill="currentColor"/>
            </svg>
            Une erreur est survenue. Veuillez réessayer ou nous contacter directement.
          </div>

          <!-- ROW 1 : Nom + Société -->
          <div class="form-v2-row form-v2-row-2">

            <div class="form-v2-field">
              <input
                class="form-v2-input"
                type="text"
                id="nom"
                name="nom"
                placeholder=" "
                autocomplete="name"
                required
                aria-required="true"
                aria-describedby="nom-error"
              />
              <label class="form-v2-label" for="nom">
                Nom complet <span class="form-v2-req" aria-hidden="true">*</span>
              </label>
              <span class="form-v2-line" aria-hidden="true"></span>
              <span id="nom-error" class="form-v2-error" hidden>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                  <line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2"/>
                  <circle cx="12" cy="16" r="1" fill="currentColor"/>
                </svg>
                Ce champ est obligatoire
              </span>
            </div>

            <div class="form-v2-field">
              <input
                class="form-v2-input"
                type="text"
                id="societe"
                name="societe"
                placeholder=" "
                autocomplete="organization"
              />
              <label class="form-v2-label" for="societe">Société</label>
              <span class="form-v2-line" aria-hidden="true"></span>
            </div>

          </div>

          <!-- ROW 2 : Email + Téléphone -->
          <div class="form-v2-row form-v2-row-2">

            <div class="form-v2-field">
              <input
                class="form-v2-input"
                type="email"
                id="email"
                name="email"
                placeholder=" "
                autocomplete="email"
                required
                aria-required="true"
                aria-describedby="email-error"
              />
              <label class="form-v2-label" for="email">
                Email <span class="form-v2-req" aria-hidden="true">*</span>
              </label>
              <span class="form-v2-line" aria-hidden="true"></span>
              <span id="email-error" class="form-v2-error" hidden>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                  <line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2"/>
                  <circle cx="12" cy="16" r="1" fill="currentColor"/>
                </svg>
                Veuillez entrer un email valide
              </span>
            </div>

            <div class="form-v2-field">
              <input
                class="form-v2-input"
                type="tel"
                id="telephone"
                name="telephone"
                placeholder=" "
                autocomplete="tel"
              />
              <label class="form-v2-label" for="telephone">Téléphone</label>
              <span class="form-v2-line" aria-hidden="true"></span>
            </div>

          </div>

          <!-- ROW 3 : Type de projet (select custom) -->
          <div class="form-v2-row">

            <div class="form-v2-field form-v2-field-select">
              <select
                class="form-v2-input form-v2-select"
                id="type-projet"
                name="type_projet"
                required
                aria-required="true"
                aria-describedby="type-error"
              >
                <option value="" disabled selected hidden></option>
                <option value="Renforcement structurel">Renforcement structurel</option>
                <option value="Réhabilitation technique">Réhabilitation technique</option>
                <option value="Conception & aménagement de points de vente">Conception & aménagement de points de vente</option>
                <option value="Menuiserie et aluminium">Menuiserie et aluminium</option>
                <option value="Pilotage & coordination de chantier (OPC)">Pilotage & coordination de chantier (OPC)</option>
                <option value="Aménagements tertiaires & finitions">Aménagements tertiaires & finitions</option>
                <option value="Autre">Autre / Je ne sais pas encore</option>
              </select>
              <label class="form-v2-label" for="type-projet">
                Type de projet <span class="form-v2-req" aria-hidden="true">*</span>
              </label>
              <svg class="form-v2-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="form-v2-line" aria-hidden="true"></span>
              <span id="type-error" class="form-v2-error" hidden>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                  <line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2"/>
                  <circle cx="12" cy="16" r="1" fill="currentColor"/>
                </svg>
                Veuillez sélectionner un type de projet
              </span>
            </div>

          </div>

          <!-- ROW 4 : Budget (select custom) -->
          <div class="form-v2-row">

            <div class="form-v2-field form-v2-field-select">
              <select class="form-v2-input form-v2-select" id="budget" name="budget">
                <option value="" disabled selected hidden></option>
                <option value="Moins de 50 000 €">Moins de 50 000 €</option>
                <option value="50 000 – 200 000 €">50 000 – 200 000 €</option>
                <option value="200 000 – 500 000 €">200 000 – 500 000 €</option>
                <option value="500 000 – 1 000 000 €">500 000 – 1 000 000 €</option>
                <option value="Plus de 1 000 000 €">Plus de 1 000 000 €</option>
                <option value="Non défini">Non défini pour l'instant</option>
              </select>
              <label class="form-v2-label" for="budget">Budget estimé (facultatif)</label>
              <svg class="form-v2-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="form-v2-line" aria-hidden="true"></span>
            </div>

          </div>

          <!-- ROW 5 : Message (textarea) -->
          <div class="form-v2-row">

            <div class="form-v2-field form-v2-field-textarea">
              <textarea
                class="form-v2-input form-v2-textarea"
                id="message"
                name="message"
                placeholder=" "
                rows="5"
                maxlength="2000"
                required
                aria-required="true"
                aria-describedby="message-error message-counter"
              ></textarea>
              <label class="form-v2-label" for="message">
                Description du projet <span class="form-v2-req" aria-hidden="true">*</span>
              </label>
              <span class="form-v2-line" aria-hidden="true"></span>
              <span id="message-counter" class="form-v2-counter" aria-live="polite">
                <span id="msg-count">0</span>/2000
              </span>
              <span id="message-error" class="form-v2-error" hidden>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                  <line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2"/>
                  <circle cx="12" cy="16" r="1" fill="currentColor"/>
                </svg>
                Veuillez décrire votre projet
              </span>
              <span class="form-v2-hint">Localisation, superficie, contraintes, délais souhaités…</span>
            </div>

          </div>

          <div class="form-v2-footer">
            <p class="form-v2-legal">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor" stroke-width="2"/>
              </svg>
              En soumettant ce formulaire, vous acceptez que vos données soient utilisées pour traiter votre demande.
              <a href="/confidentialite">Politique de confidentialité</a>
            </p>
            <button class="form-v2-submit" type="submit" id="submit-btn">
              <span id="submit-label">
                Envoyer ma demande
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span id="submit-loading" hidden aria-live="polite">
                <span class="form-v2-spinner" aria-hidden="true"></span>
                Envoi en cours…
              </span>
            </button>
          </div>

        </form>
      </div>
    </div>
  </section>

  <!-- ████ TIMELINE — Ce qui se passe après ████ -->
  <section class="contact-timeline" aria-labelledby="tl-h2">
    <div class="contact-timeline-inner">

      <div class="s-head-v2 reveal">
        <div>
          <span class="s-tag">Après votre demande</span>
          <h2 id="tl-h2" class="s-title-v2">
            COMMENT ÇA<br/><em>SE PASSE.</em>
          </h2>
        </div>
      </div>

      <ol class="timeline-list stagger" role="list">

        <li class="timeline-step" role="listitem">
          <span class="timeline-num">01</span>
          <div class="timeline-body">
            <h3>Réception & analyse</h3>
            <p>Notre équipe étudie votre demande dès sa réception et identifie les points-clés du projet.</p>
          </div>
        </li>

        <li class="timeline-step" role="listitem">
          <span class="timeline-num">02</span>
          <div class="timeline-body">
            <h3>Premier contact</h3>
            <p>Un de nos chargés d'affaires vous contacte pour affiner le périmètre et planifier — si nécessaire — une visite technique.</p>
          </div>
        </li>

        <li class="timeline-step" role="listitem">
          <span class="timeline-num">03</span>
          <div class="timeline-body">
            <h3>Étude technique</h3>
            <p>Notre bureau d'étude élabore la faisabilité technique : méthode, planning, contraintes spécifiques (site occupé, MASE…).</p>
          </div>
        </li>

        <li class="timeline-step" role="listitem">
          <span class="timeline-num">04</span>
          <div class="timeline-body">
            <h3>Devis détaillé</h3>
            <p>Vous recevez un devis détaillé et chiffré, ligne par ligne — sans surprise ni coût caché.</p>
          </div>
        </li>

      </ol>
    </div>
  </section>

  <!-- ████ CARTE GOOGLE MAPS ████ -->
  <section class="contact-map" aria-label="Localisation Eurolook Construction">
    <div class="contact-map-inner">

      <div class="contact-map-side reveal-left">
        <span class="s-tag">Nos bureaux</span>
        <h2 class="about-title">
          BOUC-BEL-AIR<br/><em>PROVENCE.</em>
        </h2>
        <p>
          Implantée au cœur des Bouches-du-Rhône, à proximité immédiate d'Aix-en-Provence et de l'autoroute A51.
          Zone d'intervention : France entière et marchés internationaux.
        </p>
        <address class="contact-address">
          <strong>Eurolook Construction</strong><br/>
          309 Rue Louis Lépine<br/>
          13320 Bouc-Bel-Air<br/>
          France
        </address>
        <a href="https://maps.google.com/?q=309+Rue+Louis+Lépine+13320+Bouc-Bel-Air" target="_blank" rel="noopener" class="about-link">
          Itinéraire Google Maps
          <svg width="20" height="12" viewBox="0 0 20 12" fill="none" aria-hidden="true">
            <path d="M14 1L19 6L14 11M19 6H1" stroke="currentColor" stroke-width="2"/>
          </svg>
        </a>
      </div>

      <div class="contact-map-frame reveal-right">
        <iframe
          src="https://www.google.com/maps?q=309+Rue+Louis+L%C3%A9pine+13320+Bouc-Bel-Air&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Carte de localisation Eurolook Construction"
        ></iframe>
      </div>

    </div>
  </section>

  <!-- ████ CTA FINALE ████ -->
  <section class="cta-band-v2" aria-labelledby="contact-cta-h2">
    <div class="cta-band-v2-inner reveal">
      <h2 id="contact-cta-h2">PENSER<br/>PLUS <em>GRAND.</em></h2>
      <div>
        <p>Une question, un projet à discuter ? Notre équipe est à votre écoute.</p>
        <br>
        <a href="tel:0983039959" class="btn btn-dark">09 83 03 99 59</a>
      </div>
    </div>
  </section>

</Layout>

<script>
(function(){
  var form = document.getElementById('contact-form');
  var success = document.getElementById('form-success');
  var errorBox = document.getElementById('form-error');
  var submitBtn = document.getElementById('submit-btn');
  var submitLabel = document.getElementById('submit-label');
  var submitLoading = document.getElementById('submit-loading');

  if(!form) return;

  // Compteur textarea
  var msgInput = document.getElementById('message');
  var msgCount = document.getElementById('msg-count');
  if(msgInput && msgCount){
    msgInput.addEventListener('input', function(){
      msgCount.textContent = msgInput.value.length;
    });
  }

  // Floating label pour les selects (ajout classe has-value)
  form.querySelectorAll('.form-v2-select').forEach(function(sel){
    function updateSelectState(){
      if(sel.value){
        sel.classList.add('has-value');
      } else {
        sel.classList.remove('has-value');
      }
    }
    sel.addEventListener('change', updateSelectState);
    updateSelectState();
  });

  var fields = {
    nom: { el: document.getElementById('nom'), err: document.getElementById('nom-error') },
    email: { el: document.getElementById('email'), err: document.getElementById('email-error') },
    'type-projet': { el: document.getElementById('type-projet'), err: document.getElementById('type-error') },
    message: { el: document.getElementById('message'), err: document.getElementById('message-error') }
  };

  Object.values(fields).forEach(function(f){
    if(f.el){
      f.el.addEventListener('blur', function(){ validateField(f); });
      f.el.addEventListener('input', function(){ if(f.err && !f.err.hidden) validateField(f); });
    }
  });

  function validateField(f){
    var ok = f.el.checkValidity();
    if(f.err) f.err.hidden = ok;
    f.el.setAttribute('aria-invalid', String(!ok));
    return ok;
  }

  function validateAll(){
    var ok = true;
    Object.values(fields).forEach(function(f){ if(!validateField(f)) ok = false; });
    return ok;
  }

  form.addEventListener('submit', async function(e){
    e.preventDefault();
    if(!validateAll()) return;

    submitBtn.disabled = true;
    submitLabel.hidden = true;
    submitLoading.hidden = false;
    if(errorBox) errorBox.hidden = true;

    try {
      var res = await fetch('https://formspree.io/f/xbdbljey', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: new FormData(form)
      });
      var json = await res.json();

      if(res.ok){
        form.hidden = true;
        if(success) success.hidden = false;
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        throw new Error(json.message || 'Erreur inconnue');
      }
    } catch(err) {
      submitBtn.disabled = false;
      submitLabel.hidden = false;
      submitLoading.hidden = true;
      if(errorBox) errorBox.hidden = false;
    }
  });
})();
</script>
