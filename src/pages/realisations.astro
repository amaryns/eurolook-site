---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Nos Réalisations — Eurolook Construction | 200+ projets depuis 2015"
  description="Découvrez les réalisations d'Eurolook Construction : renforcement structurel, réhabilitation technique, aménagement commercial. 200+ projets livrés depuis 2015."
  canonical="https://eurolookgroup.com/realisations"
>

  <!-- ████ EN-TÊTE ████ -->
  <div class="real-header">
    <nav aria-label="Fil d'Ariane">
      <p class="breadcrumb">
        <a href="/" style="color:inherit;text-decoration:none;">Accueil</a>
        &nbsp;→&nbsp; Réalisations
      </p>
    </nav>
    <h1 id="real-h1" class="real-h1">NOS<br>RÉALISATIONS</h1>
    <p class="real-intro">200+ projets depuis 2015 — renforcement structurel, réhabilitation technique et aménagement commercial.</p>
  </div>

  <!-- ████ FILTRES ████ -->
  <div class="filters" role="group" aria-label="Filtrer par catégorie">
    <button class="filter-btn is-active" data-cat="" aria-pressed="true">Tous</button>
    <button class="filter-btn" data-cat="commercial" aria-pressed="false">Commercial</button>
    <button class="filter-btn" data-cat="structure" aria-pressed="false">Structure</button>
    <button class="filter-btn" data-cat="residentiel" aria-pressed="false">Résidentiel</button>
    <button class="filter-btn" data-cat="industriel" aria-pressed="false">Industriel</button>
    <button class="filter-btn" data-cat="aluminium" aria-pressed="false">Aluminium</button>
  </div>

  <!-- CTA rapide -->
  <div style="padding:1.5rem var(--gap) 0;background:var(--pfull-bg);display:flex;justify-content:flex-end;">
    <a class="btn btn-gold btn-sm" href="/contact">Demander un devis</a>
  </div>

  <!-- ████ GRILLE PROJETS ████ -->
  <div class="proj-full-grid" role="list">

    <a href="/realisations/four-poche-arcelormittal" class="proj-card-link" role="listitem" aria-label="Voir la fiche projet : Four Poche ArcelorMittal">
      <article class="proj-full-card" data-cat="industriel">
        <img
          src="/images/realisations/four-poche/05-pompe-beton.jpg"
          alt="Four Poche ArcelorMittal — Eurolook Construction"
          loading="lazy"
          width="700"
          height="280"
        />
        <div class="proj-card-info">
          <span class="proj-cat">Industriel</span>
          <h3 class="proj-name">Four Poche ArcelorMittal</h3>
          <span class="proj-meta">Fos-sur-Mer · Février 2023</span>
          <p class="proj-snippet">Sous-traitance Eiffage Génie Civil — gros-œuvre béton (radier armé, murs blocs) pour locaux techniques industriels en environnement ATEX.</p>
        </div>
      </article>
    </a>

    <a href="/realisations/viaxoft-marseille" class="proj-card-link" role="listitem" aria-label="Voir la fiche projet : ViaXoft Marseille">
      <article class="proj-full-card" data-cat="commercial">
        <img
          src="/images/realisations/viaxoft-marseille/07-vue-ensemble.jpg"
          alt="Le ViaXoft Marseille — Eurolook Construction"
          loading="lazy"
          width="700"
          height="280"
        />
        <div class="proj-card-info">
          <span class="proj-cat">Commercial</span>
          <h3 class="proj-name">Le ViaXoft Marseille</h3>
          <span class="proj-meta">Marseille 13e · Novembre 2023</span>
          <p class="proj-snippet">Sous-traitance MRSE — lot gros œuvre complet d'un bâtiment tertiaire R+1 contemporain, ZAC Château Gombert. Architecte : Atelier Yvann Pluskwa.</p>
        </div>
      </article>
    </a>

  </div>

  <!-- ████ CTA BAS DE PAGE ████ -->
  <div class="real-cta">
    <p>Votre chantier pourrait être le suivant</p>
    <a class="btn btn-gold" href="/contact" aria-label="Demander un devis gratuit">Demander un devis</a>
  </div>

</Layout>

<style>
  .proj-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform .3s ease, box-shadow .3s ease;
  }
  .proj-card-link:hover {
    transform: translateY(-4px);
  }
  .proj-card-link:focus-visible {
    outline: 3px solid #B8934A;
    outline-offset: 4px;
    border-radius: 2px;
  }
</style>
