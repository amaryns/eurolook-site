---
// src/pages/realisations/viaxoft-marseille.astro
// Fiche projet — Le ViaXoft (bureaux contemporains)
// Sous-traitance MRSE — ZAC Château Gombert, Marseille 13e

import Layout from '../../layouts/Layout.astro';

const title = "Le ViaXoft Marseille — Réalisation Eurolook Construction";
const description = "Construction d'un bâtiment de bureaux contemporains R+1 pour ViaXoft, ZAC Château Gombert, Marseille 13e. Lot gros œuvre en sous-traitance MRSE.";
---

<Layout title={title} description={description}>

  <article class="fp" aria-labelledby="fp-title">

    <!-- HERO -->
    <header class="fp-hero">
      <div class="fp-hero-bg" aria-hidden="true">
        <img src="/images/realisations/viaxoft-marseille/07-vue-ensemble.jpg" alt="" fetchpriority="high" />
      </div>
      <div class="fp-hero-ov" aria-hidden="true"></div>
      <div class="fp-hero-body">
        <div class="fp-hero-inner">
          <div class="fp-cat">Tertiaire · Bureaux contemporains</div>
          <h1 id="fp-title">LE VIAXOFT<br><span class="hero-accent">MARSEILLE</span></h1>
          <p class="fp-loc"><span aria-hidden="true">📍</span><span>Rue Marc Donadille, 13013 Marseille — ZAC Château Gombert</span></p>
        </div>
      </div>
    </header>

    <!-- BANDEAU KPIs -->
    <div class="fp-kpis-wrap">
      <div class="fp-kpis" role="list">
        <div class="fp-kpi" role="listitem"><span class="fp-kpi-l">Budget HT</span><span class="fp-kpi-v">800 000 €</span></div>
        <div class="fp-kpi" role="listitem"><span class="fp-kpi-l">Niveaux</span><span class="fp-kpi-v">R+1</span></div>
        <div class="fp-kpi" role="listitem"><span class="fp-kpi-l">Durée</span><span class="fp-kpi-v">5 mois</span></div>
        <div class="fp-kpi" role="listitem"><span class="fp-kpi-l">Livraison</span><span class="fp-kpi-v">Nov. 2023</span></div>
        <div class="fp-kpi" role="listitem"><span class="fp-kpi-l">Lieu</span><span class="fp-kpi-v">Marseille 13e</span></div>
      </div>
    </div>

    <div class="fp-content">

      <!-- PRÉSENTATION -->
      <section class="fp-section" aria-labelledby="fp-presentation">
        <h2 id="fp-presentation" class="fp-h2">Présentation du projet</h2>
        <div class="fp-body">
          <p>Construction d'un ensemble de bureaux contemporains pour la société <strong>ViaXoft</strong>, éditeur de logiciels de tourisme pour les agences de voyage, au cœur de la ZAC Château Gombert à Marseille.</p>
          <p>Eurolook Construction est intervenue en sous-traitance de l'entreprise générale <strong>MRSE</strong>, sous la maîtrise d'œuvre de l'<strong>Atelier d'Architecture Yvann Pluskwa</strong>, pour la réalisation complète du lot gros œuvre d'un bâtiment tertiaire R+1.</p>
          <p>L'opération a nécessité une exécution rigoureuse afin de répondre aux exigences architecturales du projet, notamment sur les volumes, les porte-à-faux, les finitions béton et l'intégration des différents équipements techniques.</p>
        </div>
      </section>

      <!-- GALERIE -->
      <section class="fp-section" aria-labelledby="fp-galerie">
        <h2 id="fp-galerie" class="fp-h2">Galerie photos</h2>
        <div class="fp-gallery">
          <div class="fp-gallery-main">
            <img src="/images/realisations/viaxoft-marseille/05-superstructure-r1.jpg" alt="Superstructure R+1 du ViaXoft en cours de construction" loading="lazy" decoding="async" data-zoom>
          </div>
          <img src="/images/realisations/viaxoft-marseille/01-installation-chantier.jpg" alt="Installation et démarrage du chantier ViaXoft" loading="lazy" decoding="async" data-zoom>
          <img src="/images/realisations/viaxoft-marseille/02-fondations.jpg" alt="Fondations et infrastructures béton armé" loading="lazy" decoding="async" data-zoom>
          <img src="/images/realisations/viaxoft-marseille/03-elevation-voiles.jpg" alt="Élévation des voiles en béton armé" loading="lazy" decoding="async" data-zoom>
          <img src="/images/realisations/viaxoft-marseille/04-coulage-dalle.jpg" alt="Coulage des dalles béton" loading="lazy" decoding="async" data-zoom>
          <img src="/images/realisations/viaxoft-marseille/06-finitions-beton.jpg" alt="Finitions béton apparent et porte-à-faux" loading="lazy" decoding="async" data-zoom>
          <img src="/images/realisations/viaxoft-marseille/07-vue-ensemble.jpg" alt="Vue d'ensemble du bâtiment ViaXoft" loading="lazy" decoding="async" data-zoom>
        </div>
        <p class="fp-gallery-hint">Touchez une photo pour l'agrandir</p>
      </section>

      <!-- MISSIONS -->
      <section class="fp-section" aria-labelledby="fp-missions-h">
        <h2 id="fp-missions-h" class="fp-h2">Missions réalisées</h2>
        <div class="fp-missions">
          <div class="fp-mission">Infrastructures et superstructures en béton armé</div>
          <div class="fp-mission">Voiles et dalles béton</div>
          <div class="fp-mission">Escaliers béton</div>
          <div class="fp-mission">Patios et terrasses accessibles</div>
          <div class="fp-mission">Aménagements extérieurs</div>
          <div class="fp-mission">Ouvrages techniques et réservations pour corps d'état secondaires</div>
          <div class="fp-mission">Exécution des porte-à-faux et volumes architecturaux</div>
          <div class="fp-mission">Finitions béton soignées (béton apparent)</div>
        </div>
      </section>

      <!-- SPÉCIFICITÉS -->
      <section class="fp-section" aria-labelledby="fp-spec">
        <h2 id="fp-spec" class="fp-h2">Spécificités techniques</h2>
        <div class="fp-contraintes">
          <div class="fp-contrainte">
            <div class="fp-c-dot" aria-hidden="true"></div>
            <div class="fp-c-txt"><strong>Volumes architecturaux contemporains</strong> — Réalisation de porte-à-faux et de géométries complexes répondant au dessin de l'Atelier d'Architecture Yvann Pluskwa</div>
          </div>
          <div class="fp-contrainte">
            <div class="fp-c-dot" aria-hidden="true"></div>
            <div class="fp-c-txt"><strong>Finitions béton apparent</strong> — Exigences esthétiques élevées sur les surfaces visibles, coffrages soignés et calepinage maîtrisé</div>
          </div>
          <div class="fp-contrainte">
            <div class="fp-c-dot" aria-hidden="true"></div>
            <div class="fp-c-txt"><strong>Intégration multi-corps</strong> — Réservations et ouvrages techniques pour CVC, électricité, plomberie et tous corps d'état secondaires</div>
          </div>
          <div class="fp-contrainte">
            <div class="fp-c-dot" aria-hidden="true"></div>
            <div class="fp-c-txt"><strong>Coordination MOE / entreprise générale</strong> — Sous-traitance de MRSE en lien direct avec la maîtrise d'œuvre architecturale</div>
          </div>
        </div>
      </section>

      <!-- INFOS COMPLÉMENTAIRES -->
      <section class="fp-section" aria-labelledby="fp-infos">
        <h2 id="fp-infos" class="fp-h2">Informations complémentaires</h2>
        <div class="fp-info-grid">
          <div class="fp-info-card">
            <h3>Données du marché</h3>
            <div class="fp-dl">
              <span class="fp-dt">Maître d'ouvrage</span>
              <span class="fp-dd">SCI Scampy</span>
              <span class="fp-dt">Maître d'œuvre</span>
              <span class="fp-dd">Atelier d'Architecture Yvann Pluskwa</span>
              <span class="fp-dt">Entreprise générale</span>
              <span class="fp-dd">MRSE</span>
              <span class="fp-dt">Type de projet</span>
              <span class="fp-dd">Lot gros œuvre — Bâtiment tertiaire R+1</span>
              <span class="fp-dt">Période d'exécution</span>
              <span class="fp-dd">Juillet — Novembre 2023</span>
              <span class="fp-dt">Mode d'intervention</span>
              <span class="fp-dd">Sous-traitance · Entreprise générale MRSE</span>
            </div>
          </div>
        </div>
      </section>

    </div>

    <!-- CTA -->
    <aside class="fp-cta" aria-label="Demande de devis">
      <div class="fp-cta-inner">
        <p>Un projet similaire<br><span class="gold">à nous confier ?</span></p>
        <a href="/contact" class="btn-gold">Demander un devis</a>
      </div>
    </aside>

    <!-- NAV PROJETS -->
    <nav class="fp-nav-bar" aria-label="Retour aux réalisations">
      <a href="/realisations" class="fp-nav-btn">← Toutes les réalisations</a>
    </nav>

  </article>

  <!-- LIGHTBOX -->
  <div id="fp-lightbox" class="fp-lightbox" hidden role="dialog" aria-modal="true" aria-label="Photo agrandie">
    <button id="fp-lightbox-close" class="fp-lightbox-close" aria-label="Fermer la photo">×</button>
    <div id="fp-lightbox-loader" class="fp-lightbox-loader" aria-hidden="true">
      <div class="fp-spinner"></div>
    </div>
    <img id="fp-lightbox-img" class="fp-lightbox-img" src="" alt="">
  </div>

</Layout>

<style>
  .fp{font-family:'Barlow',sans-serif;background:#0C0B09;color:#F9F5EE;}
  .gold{color:#B8934A;}
  .hero-accent{color:#B8934A;}

  /* ════ HERO ════ */
  .fp-hero{position:relative;height:clamp(360px,55vh,620px);display:flex;align-items:flex-end;overflow:hidden;}
  .fp-hero-bg{position:absolute;inset:0;}
  .fp-hero-bg img{width:100%;height:100%;object-fit:cover;filter:brightness(.5);}
  .fp-hero-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(12,11,9,.95) 0%,rgba(12,11,9,.2) 50%,rgba(12,11,9,.4) 100%);}
  .fp-hero-body{position:relative;z-index:2;width:100%;padding:3rem 0;}
  .fp-hero-inner{max-width:1280px;margin:0 auto;padding:0 clamp(1.25rem,4vw,3rem);}
  .fp-cat{display:inline-flex;align-items:center;gap:.5rem;font-family:'Barlow Condensed',sans-serif;font-size:.8125rem;font-weight:600;letter-spacing:.3em;text-transform:uppercase;color:#B8934A;margin-bottom:1rem;}
  .fp-cat::before{content:'';display:block;width:24px;height:2px;background:#B8934A;}
  .fp-hero h1{font-family:'Barlow Condensed',sans-serif;font-size:clamp(1.875rem,6vw,4.5rem);font-weight:800;letter-spacing:.03em;text-transform:uppercase;color:#F9F5EE;line-height:1;margin-bottom:1rem;}
  .fp-loc{font-size:clamp(.875rem,1.2vw,1.0625rem);color:rgba(249,245,238,.8);display:flex;align-items:center;gap:.5rem;margin:0;}

  /* ════ KPIs ════ */
  .fp-kpis-wrap{background:#182338;border-bottom:3px solid #B8934A;}
  .fp-kpis{display:grid;grid-template-columns:repeat(5,1fr);max-width:1280px;margin:0 auto;}
  .fp-kpi{padding:1.75rem 1rem;text-align:center;border-right:1px solid rgba(184,147,74,.15);}
  .fp-kpi:last-child{border-right:none;}
  .fp-kpi-l{display:block;font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:rgba(249,245,238,.65);margin-bottom:.5rem;}
  .fp-kpi-v{font-family:'Barlow Condensed',sans-serif;font-size:1.375rem;font-weight:800;color:#DFC08A;letter-spacing:.04em;text-transform:uppercase;line-height:1.1;}

  /* ════ CONTENT ════ */
  .fp-content{max-width:1100px;margin:0 auto;padding:clamp(2.5rem,6vw,5rem) clamp(1.25rem,4vw,3rem);}
  .fp-section{margin-bottom:4rem;}
  .fp-section:last-child{margin-bottom:0;}
  .fp-h2{font-family:'Barlow Condensed',sans-serif;font-size:clamp(1.375rem,2.5vw,1.875rem);font-weight:800;letter-spacing:.06em;text-transform:uppercase;color:#F9F5EE;border-left:4px solid #B8934A;padding-left:1.25rem;margin-bottom:1.75rem;}
  .fp-body{font-size:1.0625rem;color:rgba(249,245,238,.78);line-height:1.875;max-width:780px;}
  .fp-body p+p{margin-top:1.125rem;}
  .fp-body strong{color:#DFC08A;font-weight:600;}

  /* ════ GALERIE — Mobile-first ════ */
  .fp-gallery{display:grid;grid-template-columns:1fr;gap:.75rem;}
  .fp-gallery-main{grid-column:1/-1;}
  .fp-gallery img{
    width:100%;
    aspect-ratio:4/3;
    object-fit:cover;
    border-radius:3px;
    filter:brightness(.92);
    transition:filter .3s,transform .3s;
    cursor:zoom-in;
    display:block;
    background:#151310;
  }
  .fp-gallery img:hover,
  .fp-gallery img:focus{filter:brightness(1);transform:scale(1.01);}
  .fp-gallery-main img{aspect-ratio:16/9;}
  .fp-gallery-hint{text-align:center;margin-top:1.25rem;font-size:.875rem;color:rgba(249,245,238,.45);font-style:italic;}

  /* ════ MISSIONS ════ */
  .fp-missions{display:grid;grid-template-columns:1fr;gap:.75rem;}
  .fp-mission{font-size:.9375rem;color:rgba(249,245,238,.82);padding:1.125rem 1.375rem;background:#151310;border-left:4px solid #B8934A;border-radius:0 3px 3px 0;line-height:1.5;}

  /* ════ INFOS ════ */
  .fp-info-grid{display:grid;grid-template-columns:1fr;gap:1.25rem;}
  .fp-info-card{background:#151310;border:1px solid rgba(184,147,74,.12);border-radius:3px;padding:1.5rem;}
  .fp-info-card h3{font-family:'Barlow Condensed',sans-serif;font-size:.9375rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#DFC08A;margin-bottom:1.25rem;padding-bottom:1rem;border-bottom:1px solid rgba(184,147,74,.12);}
  .fp-dl{display:grid;grid-template-columns:1fr;gap:.875rem;}
  .fp-dt{font-size:.8125rem;letter-spacing:.1em;text-transform:uppercase;color:#9A8870;display:block;margin-bottom:.25rem;}
  .fp-dd{font-size:1rem;font-weight:600;color:#F9F5EE;display:block;}

  /* ════ CONTRAINTES / SPÉCIFICITÉS ════ */
  .fp-contraintes{display:flex;flex-direction:column;gap:.75rem;}
  .fp-contrainte{display:flex;align-items:flex-start;gap:1rem;padding:1.125rem 1.375rem;background:#151310;border:1px solid rgba(184,147,74,.1);border-radius:3px;}
  .fp-c-dot{width:10px;height:10px;background:#B8934A;border-radius:50%;flex-shrink:0;margin-top:.4rem;}
  .fp-c-txt{font-size:.9375rem;color:rgba(249,245,238,.78);line-height:1.65;}
  .fp-c-txt strong{color:#DFC08A;}

  /* ════ CTA ════ */
  .fp-cta{background:#182338;border-top:3px solid #B8934A;border-bottom:1px solid rgba(184,147,74,.18);}
  .fp-cta-inner{max-width:1280px;margin:0 auto;padding:clamp(2rem,4vw,3.5rem) clamp(1.25rem,4vw,3rem);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;}
  .fp-cta p{font-family:'Barlow Condensed',sans-serif;font-size:clamp(1.125rem,2vw,1.625rem);font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#F9F5EE;margin:0;line-height:1.2;}
  .btn-gold{display:inline-flex;align-items:center;justify-content:center;background:#B8934A;color:#0C0B09;font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:1rem 2.25rem;border:none;border-radius:2px;cursor:pointer;text-decoration:none;transition:background .2s;}
  .btn-gold:hover{background:#CCA96A;}

  /* ════ NAV ════ */
  .fp-nav-bar{display:flex;justify-content:center;padding:1.5rem clamp(1.25rem,4vw,3rem);background:#151310;border-top:1px solid rgba(184,147,74,.12);}
  .fp-nav-btn{display:inline-flex;align-items:center;background:transparent;border:1.5px solid rgba(184,147,74,.25);color:#B8934A;font-family:'Barlow Condensed',sans-serif;font-size:.9375rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.875rem 1.5rem;border-radius:2px;text-decoration:none;transition:all .2s;}
  .fp-nav-btn:hover{background:#182338;color:#F9F5EE;border-color:#182338;}

  /* ════ LIGHTBOX ════ */
  .fp-lightbox{position:fixed;inset:0;z-index:9999;background:rgba(12,11,9,.96);display:flex;align-items:center;justify-content:center;padding:clamp(.5rem,4vw,3rem);cursor:zoom-out;animation:fpFade .25s ease;}
  .fp-lightbox[hidden]{display:none;}
  .fp-lightbox-img{max-width:100%;max-height:100%;object-fit:contain;border-radius:4px;box-shadow:0 25px 80px rgba(0,0,0,.6);opacity:0;transition:opacity .35s ease;}
  .fp-lightbox-img.is-loaded{opacity:1;}
  .fp-lightbox-loader{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;}
  .fp-lightbox-loader[hidden]{display:none;}
  .fp-spinner{width:48px;height:48px;border:3px solid rgba(184,147,74,.2);border-top-color:#B8934A;border-radius:50%;animation:fpSpin .8s linear infinite;}
  .fp-lightbox-close{position:absolute;top:1rem;right:1rem;width:48px;height:48px;background:rgba(184,147,74,.15);border:1.5px solid rgba(184,147,74,.4);color:#DFC08A;font-size:1.75rem;line-height:1;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;z-index:2;}
  .fp-lightbox-close:hover{background:#B8934A;color:#0C0B09;border-color:#B8934A;}
  @keyframes fpFade{from{opacity:0}to{opacity:1}}
  @keyframes fpSpin{to{transform:rotate(360deg)}}

  /* ════ RESPONSIVE ════ */
  @media (min-width: 640px) {
    .fp-gallery{grid-template-columns:repeat(2,1fr);gap:1rem;}
    .fp-gallery img{aspect-ratio:auto;height:220px;}
    .fp-gallery-main img{aspect-ratio:auto;height:clamp(300px,40vw,440px);}
    .fp-missions{grid-template-columns:1fr 1fr;}
    .fp-dl{grid-template-columns:1fr 1fr;gap:1.25rem 2rem;}
  }
  @media (min-width: 1024px) {
    .fp-gallery{grid-template-columns:repeat(4,1fr);}
    .fp-gallery img{height:200px;}
    .fp-gallery-main{grid-column:1/-1;}
    .fp-gallery-main img{height:clamp(380px,40vw,480px);}
    .fp-missions{grid-template-columns:repeat(3,1fr);}
  }
  @media (max-width: 639px) {
    .fp-kpis{grid-template-columns:repeat(2,1fr);}
    .fp-kpi{border-bottom:1px solid rgba(184,147,74,.15);padding:1.25rem .75rem;}
    .fp-kpi:nth-child(2n){border-right:none;}
    .fp-kpi:nth-child(5){grid-column:1/-1;border-bottom:none;}
    .fp-kpi-v{font-size:1.125rem;}
    .fp-cta-inner{flex-direction:column;align-items:flex-start;text-align:left;}
    .fp-cta-inner .btn-gold{width:100%;}
  }
</style>

<script>
  const lightbox = document.getElementById('fp-lightbox');
  const lightboxImg = document.getElementById('fp-lightbox-img');
  const lightboxLoader = document.getElementById('fp-lightbox-loader');
  const lightboxClose = document.getElementById('fp-lightbox-close');
  const zoomImgs = document.querySelectorAll('[data-zoom]');

  function openLightbox(src, alt) {
    lightboxImg.classList.remove('is-loaded');
    lightboxImg.src = '';
    lightboxImg.alt = '';
    lightboxLoader.hidden = false;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';

    const tempImg = new Image();
    tempImg.onload = () => {
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      lightboxImg.classList.add('is-loaded');
      lightboxLoader.hidden = true;
    };
    tempImg.onerror = () => { lightboxLoader.hidden = true; };
    tempImg.src = src;
  }

  function closeLightbox() {
    lightbox.hidden = true;
    lightboxImg.src = '';
    lightboxImg.classList.remove('is-loaded');
    lightboxLoader.hidden = false;
    document.body.style.overflow = '';
  }

  zoomImgs.forEach(img => img.addEventListener('click', () => openLightbox(img.src, img.alt)));
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox || e.target === lightboxClose) closeLightbox(); });
  lightboxClose.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !lightbox.hidden) closeLightbox(); });
</script>
