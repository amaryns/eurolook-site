---
// src/pages/realisations/four-poche-arcelormittal.astro
// Fiche projet — Construction Four Poche / ArcelorMittal
// Sous-traitance Eiffage Génie Civil — Fos-sur-Mer (13776)

import Layout from '../../layouts/Layout.astro';

const title = "Four Poche ArcelorMittal — Réalisation Eurolook Construction";
const description = "Construction des locaux techniques du four poche ArcelorMittal à Fos-sur-Mer. Sous-traitance Eiffage Génie Civil — gros-œuvre béton en environnement ATEX.";
---

<Layout title={title} description={description}>

  <article class="fp" aria-labelledby="fp-title">

    <!-- HERO -->
    <header class="fp-hero">
      <div class="fp-hero-bg" aria-hidden="true">
        <img src="/images/realisations/four-poche/05-pompe-beton.jpg" alt="" />
      </div>
      <div class="fp-hero-ov" aria-hidden="true"></div>
      <div class="fp-hero-body">
        <div class="fp-hero-inner">
          <div class="fp-cat">Site industriel · Pétrochimie</div>
          <h1 id="fp-title">FOUR POCHE<br><span class="hero-accent">ARCELOR MITTAL</span></h1>
          <p class="fp-loc"><span aria-hidden="true">📍</span><span>Fos-sur-Mer (13776) — Site industriel ArcelorMittal</span></p>
        </div>
      </div>
    </header>

    <!-- BANDEAU KPIs -->
    <div class="fp-kpis-wrap">
      <div class="fp-kpis" role="list">
        <div class="fp-kpi" role="listitem"><span class="fp-kpi-l">Budget HT</span><span class="fp-kpi-v">150 000 €</span></div>
        <div class="fp-kpi" role="listitem"><span class="fp-kpi-l">Surface</span><span class="fp-kpi-v">340 m²</span></div>
        <div class="fp-kpi" role="listitem"><span class="fp-kpi-l">Durée</span><span class="fp-kpi-v">2 mois</span></div>
        <div class="fp-kpi" role="listitem"><span class="fp-kpi-l">Livraison</span><span class="fp-kpi-v">Fév. 2023</span></div>
        <div class="fp-kpi" role="listitem"><span class="fp-kpi-l">Lieu</span><span class="fp-kpi-v">Fos-sur-Mer</span></div>
      </div>
    </div>

    <div class="fp-content">

      <!-- PRÉSENTATION -->
      <section class="fp-section" aria-labelledby="fp-presentation">
        <h2 id="fp-presentation" class="fp-h2">Présentation du projet</h2>
        <div class="fp-body">
          <p>Dans le cadre du développement d'un nouveau bâtiment de locaux techniques sur le site sidérurgique d'ArcelorMittal à Fos-sur-Mer, Eurolook Construction est intervenu en qualité de sous-traitant d'Eiffage Génie Civil pour la réalisation des ouvrages de gros-œuvre.</p>
          <p>Les travaux ont consisté en la mise en œuvre d'un radier béton armé et en l'élévation des murs en blocs de béton agglomérés, constituant le volume brut de 340 m² destiné aux futurs locaux techniques du site.</p>
          <p>Ce chantier, conduit sur un site pétrochimique en exploitation active, a nécessité une organisation rigoureuse et une maîtrise totale des protocoles de sécurité propres aux environnements industriels classifiés.</p>
        </div>
      </section>

      <!-- GALERIE -->
      <section class="fp-section" aria-labelledby="fp-galerie">
        <h2 id="fp-galerie" class="fp-h2">Galerie photos</h2>
        <div class="fp-gallery">
          <div class="fp-gallery-main">
            <img src="/images/realisations/four-poche/04-coulage-beton.jpg" alt="Coulage du béton en cours sur le chantier Four Poche ArcelorMittal" loading="lazy" data-zoom>
          </div>
          <img src="/images/realisations/four-poche/01-installation-chantier.jpg" alt="Installation du chantier au pied de l'unité industrielle" loading="lazy" data-zoom>
          <img src="/images/realisations/four-poche/02-banderole-eurolook.jpg" alt="Présence Eurolook Construction sur le site" loading="lazy" data-zoom>
          <img src="/images/realisations/four-poche/03-radier-ferraillage.jpg" alt="Ferraillage du radier béton armé" loading="lazy" data-zoom>
          <img src="/images/realisations/four-poche/06-dalle-finie.jpg" alt="Dalle béton finie après coulage" loading="lazy" data-zoom>
        </div>
        <p class="fp-gallery-hint">Cliquez sur une photo pour l'agrandir</p>
      </section>

      <!-- MISSIONS -->
      <section class="fp-section" aria-labelledby="fp-missions-h">
        <h2 id="fp-missions-h" class="fp-h2">Missions réalisées</h2>
        <div class="fp-missions">
          <div class="fp-mission">Mise en œuvre d'un radier béton armé (fondation superficielle)</div>
          <div class="fp-mission">Élévation de murs en blocs béton agglomérés</div>
          <div class="fp-mission">Implantation et réservations pour locaux techniques</div>
          <div class="fp-mission">Respect des plans d'exécution fournis par Eiffage Génie Civil</div>
          <div class="fp-mission">Application des procédures ATEX en environnement pétrochimique</div>
          <div class="fp-mission">Coordination avec les équipes industrielles en co-activité</div>
          <div class="fp-mission">Gestion des accès réglementés et plans de prévention</div>
          <div class="fp-mission">Travaux réalisés en site sensible en exploitation continue</div>
        </div>
      </section>

      <!-- CONTRAINTES -->
      <section class="fp-section" aria-labelledby="fp-contraintes">
        <h2 id="fp-contraintes" class="fp-h2">Contraintes techniques & sécuritaires</h2>
        <div class="fp-contraintes">
          <div class="fp-contrainte">
            <div class="fp-c-dot" aria-hidden="true"></div>
            <div class="fp-c-txt"><strong>Environnement ATEX</strong> — Procédures spécifiques aux zones à risque d'explosion, équipements et protocoles adaptés en permanence</div>
          </div>
          <div class="fp-contrainte">
            <div class="fp-c-dot" aria-hidden="true"></div>
            <div class="fp-c-txt"><strong>Coactivité industrielle</strong> — Coordination permanente avec les activités du site sidérurgique en pleine exploitation</div>
          </div>
          <div class="fp-contrainte">
            <div class="fp-c-dot" aria-hidden="true"></div>
            <div class="fp-c-txt"><strong>Accès réglementés</strong> — Habilitations, plans de prévention et procédures d'accès spécifiques au site ArcelorMittal</div>
          </div>
          <div class="fp-contrainte">
            <div class="fp-c-dot" aria-hidden="true"></div>
            <div class="fp-c-txt"><strong>Site sensible en exploitation</strong> — Interventions planifiées et coordonnées pour garantir la continuité opérationnelle du site</div>
          </div>
        </div>
      </section>

      <!-- INFOS COMPLÉMENTAIRES -->
      <section class="fp-section" aria-labelledby="fp-infos">
        <h2 id="fp-infos" class="fp-h2">Informations complémentaires</h2>
        <div class="fp-info-grid">
          <div class="fp-info-card">
            <h3>Données du marché</h3>
            <div class="fp-dl">
              <span class="fp-dt">Maître d'ouvrage</span>
              <span class="fp-dd">ArcelorMittal</span>
              <span class="fp-dt">Maître d'œuvre</span>
              <span class="fp-dd">Eiffage Génie Civil</span>
              <span class="fp-dt">Type de projet</span>
              <span class="fp-dd">Gros-œuvre — Locaux techniques industriels</span>
              <span class="fp-dt">Mode d'intervention</span>
              <span class="fp-dd">Sous-traitance · Site industriel en exploitation</span>
            </div>
          </div>
        </div>
      </section>

    </div>

    <!-- CTA -->
    <aside class="fp-cta" aria-label="Demande de devis">
      <div class="fp-cta-inner">
        <p>Un projet similaire<br><span class="gold">à nous confier ?</span></p>
        <a href="/contact" class="btn-gold">Demander un devis</a>
      </div>
    </aside>

    <!-- NAV PROJETS -->
    <nav class="fp-nav-bar" aria-label="Retour aux réalisations">
      <a href="/realisations" class="fp-nav-btn">← Toutes les réalisations</a>
    </nav>

  </article>

  <!-- LIGHTBOX (modale d'agrandissement photo) -->
  <div id="fp-lightbox" class="fp-lightbox" hidden role="dialog" aria-modal="true" aria-label="Photo agrandie">
    <button id="fp-lightbox-close" class="fp-lightbox-close" aria-label="Fermer la photo">×</button>
    <img id="fp-lightbox-img" src="" alt="">
  </div>

</Layout>

<style>
  .fp{font-family:'Barlow',sans-serif;background:#0C0B09;color:#F9F5EE;}
  .gold{color:#B8934A;}
  .hero-accent{color:#B8934A;}

  /* ════ HERO ════ */
  .fp-hero{position:relative;height:clamp(380px,55vh,620px);display:flex;align-items:flex-end;overflow:hidden;}
  .fp-hero-bg{position:absolute;inset:0;}
  .fp-hero-bg img{width:100%;height:100%;object-fit:cover;filter:brightness(.5);}
  .fp-hero-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(12,11,9,.95) 0%,rgba(12,11,9,.2) 50%,rgba(12,11,9,.4) 100%);}
  .fp-hero-body{position:relative;z-index:2;width:100%;padding:3rem 0;}
  .fp-hero-inner{max-width:1280px;margin:0 auto;padding:0 clamp(1.5rem,4vw,3rem);}
  .fp-cat{display:inline-flex;align-items:center;gap:.5rem;font-family:'Barlow Condensed',sans-serif;font-size:.8125rem;font-weight:600;letter-spacing:.3em;text-transform:uppercase;color:#B8934A;margin-bottom:1rem;}
  .fp-cat::before{content:'';display:block;width:24px;height:2px;background:#B8934A;}
  .fp-hero h1{font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.25rem,6vw,4.5rem);font-weight:800;letter-spacing:.03em;text-transform:uppercase;color:#F9F5EE;line-height:1;margin-bottom:1rem;}
  .fp-loc{font-size:clamp(.9375rem,1.2vw,1.0625rem);color:rgba(249,245,238,.8);display:flex;align-items:center;gap:.5rem;margin:0;}

  /* ════ KPIs ════ */
  .fp-kpis-wrap{background:#182338;border-bottom:3px solid #B8934A;}
  .fp-kpis{display:grid;grid-template-columns:repeat(5,1fr);max-width:1280px;margin:0 auto;}
  .fp-kpi{padding:1.75rem 1rem;text-align:center;border-right:1px solid rgba(184,147,74,.15);}
  .fp-kpi:last-child{border-right:none;}
  .fp-kpi-l{display:block;font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:rgba(249,245,238,.65);margin-bottom:.5rem;}
  .fp-kpi-v{font-family:'Barlow Condensed',sans-serif;font-size:1.375rem;font-weight:800;color:#DFC08A;letter-spacing:.04em;text-transform:uppercase;line-height:1.1;}

  /* ════ CONTENT (centré) ════ */
  .fp-content{max-width:1100px;margin:0 auto;padding:clamp(3rem,6vw,5rem) clamp(1.5rem,4vw,3rem);}
  .fp-section{margin-bottom:4rem;}
  .fp-section:last-child{margin-bottom:0;}
  .fp-h2{font-family:'Barlow Condensed',sans-serif;font-size:clamp(1.5rem,2.5vw,1.875rem);font-weight:800;letter-spacing:.06em;text-transform:uppercase;color:#F9F5EE;border-left:4px solid #B8934A;padding-left:1.25rem;margin-bottom:1.75rem;}
  .fp-body{font-size:1.0625rem;color:rgba(249,245,238,.78);line-height:1.875;max-width:780px;}
  .fp-body p+p{margin-top:1.125rem;}

  /* ════ GALERIE ════ */
  .fp-gallery{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;}
  .fp-gallery-main{grid-column:1/-1;}
  .fp-gallery img{
    width:100%;height:240px;object-fit:cover;border-radius:3px;
    filter:brightness(.88);transition:filter .3s,transform .3s;
    cursor:zoom-in;display:block;
  }
  .fp-gallery img:hover{filter:brightness(1);transform:scale(1.01);}
  .fp-gallery-main img{height:clamp(320px,40vw,480px);}
  .fp-gallery-hint{text-align:center;margin-top:1.25rem;font-size:.875rem;color:rgba(249,245,238,.45);font-style:italic;}

  /* ════ MISSIONS ════ */
  .fp-missions{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;}
  .fp-mission{font-size:.9375rem;color:rgba(249,245,238,.82);padding:1.125rem 1.375rem;background:#151310;border-left:4px solid #B8934A;border-radius:0 3px 3px 0;line-height:1.5;}

  /* ════ INFOS ════ */
  .fp-info-grid{display:grid;grid-template-columns:1fr;gap:1.25rem;}
  .fp-info-card{background:#151310;border:1px solid rgba(184,147,74,.12);border-radius:3px;padding:1.75rem;}
  .fp-info-card h3{font-family:'Barlow Condensed',sans-serif;font-size:.9375rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#DFC08A;margin-bottom:1.25rem;padding-bottom:1rem;border-bottom:1px solid rgba(184,147,74,.12);}
  .fp-dl{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem 2rem;}
  .fp-dt{font-size:.8125rem;letter-spacing:.1em;text-transform:uppercase;color:#9A8870;display:block;margin-bottom:.25rem;}
  .fp-dd{font-size:1rem;font-weight:600;color:#F9F5EE;display:block;}

  /* ════ CONTRAINTES ════ */
  .fp-contraintes{display:flex;flex-direction:column;gap:.75rem;}
  .fp-contrainte{display:flex;align-items:flex-start;gap:1rem;padding:1.125rem 1.375rem;background:#151310;border:1px solid rgba(184,147,74,.1);border-radius:3px;}
  .fp-c-dot{width:10px;height:10px;background:#B8934A;border-radius:50%;flex-shrink:0;margin-top:.4rem;}
  .fp-c-txt{font-size:.9375rem;color:rgba(249,245,238,.78);line-height:1.65;}
  .fp-c-txt strong{color:#DFC08A;}

  /* ════ CTA ════ */
  .fp-cta{background:#182338;border-top:3px solid #B8934A;border-bottom:1px solid rgba(184,147,74,.18);}
  .fp-cta-inner{max-width:1280px;margin:0 auto;padding:clamp(2.5rem,4vw,3.5rem) clamp(1.5rem,4vw,3rem);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:2rem;}
  .fp-cta p{font-family:'Barlow Condensed',sans-serif;font-size:clamp(1.25rem,2vw,1.625rem);font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#F9F5EE;margin:0;line-height:1.2;}
  .btn-gold{display:inline-flex;align-items:center;justify-content:center;background:#B8934A;color:#0C0B09;font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:1rem 2.25rem;border:none;border-radius:2px;cursor:pointer;text-decoration:none;transition:background .2s;}
  .btn-gold:hover{background:#CCA96A;}

  /* ════ NAV BAR ════ */
  .fp-nav-bar{display:flex;justify-content:center;padding:1.5rem clamp(1.5rem,4vw,3rem);background:#151310;border-top:1px solid rgba(184,147,74,.12);}
  .fp-nav-btn{display:inline-flex;align-items:center;background:transparent;border:1.5px solid rgba(184,147,74,.25);color:#B8934A;font-family:'Barlow Condensed',sans-serif;font-size:.9375rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.875rem 1.5rem;border-radius:2px;text-decoration:none;transition:all .2s;}
  .fp-nav-btn:hover{background:#182338;color:#F9F5EE;border-color:#182338;}

  /* ════ LIGHTBOX ════ */
  .fp-lightbox{
    position:fixed;inset:0;z-index:9999;
    background:rgba(12,11,9,.96);
    display:flex;align-items:center;justify-content:center;
    padding:clamp(1rem,4vw,3rem);
    cursor:zoom-out;
    animation:fpFade .25s ease;
  }
  .fp-lightbox[hidden]{display:none;}
  .fp-lightbox img{
    max-width:100%;max-height:100%;
    object-fit:contain;
    border-radius:4px;
    box-shadow:0 25px 80px rgba(0,0,0,.6);
    animation:fpZoomIn .3s ease;
  }
  .fp-lightbox-close{
    position:absolute;top:1.5rem;right:1.5rem;
    width:48px;height:48px;
    background:rgba(184,147,74,.15);
    border:1.5px solid rgba(184,147,74,.4);
    color:#DFC08A;font-size:1.75rem;line-height:1;
    border-radius:50%;cursor:pointer;
    display:flex;align-items:center;justify-content:center;
    transition:all .2s;
  }
  .fp-lightbox-close:hover{background:#B8934A;color:#0C0B09;border-color:#B8934A;}
  @keyframes fpFade{from{opacity:0}to{opacity:1}}
  @keyframes fpZoomIn{from{transform:scale(.92);opacity:0}to{transform:scale(1);opacity:1}}

  /* ════ RESPONSIVE ════ */
  @media (min-width: 768px) {
    .fp-gallery{grid-template-columns:repeat(4,1fr);}
    .fp-gallery img{height:200px;}
  }
  @media (min-width: 1024px) {
    .fp-missions{grid-template-columns:repeat(3,1fr);}
  }
  @media (max-width: 640px) {
    .fp-kpis{grid-template-columns:repeat(2,1fr);}
    .fp-kpi{border-bottom:1px solid rgba(184,147,74,.15);}
    .fp-kpi:nth-child(2n){border-right:none;}
    .fp-kpi:nth-child(5){grid-column:1/-1;border-bottom:none;}
    .fp-missions{grid-template-columns:1fr;}
    .fp-dl{grid-template-columns:1fr;gap:.875rem;}
    .fp-cta-inner{flex-direction:column;align-items:flex-start;text-align:left;}
    .fp-gallery img{height:180px;}
    .fp-gallery-main img{height:240px;}
  }
</style>

<script>
  // Lightbox photos cliquables
  const lightbox = document.getElementById('fp-lightbox');
  const lightboxImg = document.getElementById('fp-lightbox-img');
  const lightboxClose = document.getElementById('fp-lightbox-close');
  const zoomImgs = document.querySelectorAll('[data-zoom]');

  function openLightbox(src, alt) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.hidden = true;
    lightboxImg.src = '';
    document.body.style.overflow = '';
  }

  zoomImgs.forEach(img => {
    img.addEventListener('click', () => openLightbox(img.src, img.alt));
  });

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox || e.target === lightboxClose) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !lightbox.hidden) closeLightbox();
  });
</script>
