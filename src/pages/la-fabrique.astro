---
// src/pages/la-fabrique.astro
// Page La Fabrique — VERSION 2.0
// Refonte esthétique + corrections factuelles
// Entité du Groupe Holding MG — SAS créée en 2021

import Layout from '../layouts/Layout.astro';
---

<Layout
  title="La Fabrique — Eurolook Construction"
  description="La Fabrique — atelier de fabrication et pose de menuiseries extérieures en aluminium. Murs rideaux, portes pare-balle et coupe-feu, portes à pivots déportés. Machines FOM, partenaire Reynaers."
  canonical="https://eurolookgroupe.com/la-fabrique"
>

  <!-- ████ HERO ████ -->
  <section class="page-hero" aria-labelledby="fab-hero-h1">
    <img
      class="hero-bg-img"
      src="/images/la-fabrique-hero.webp"
      alt=""
      role="presentation"
      loading="eager"
      fetchpriority="high"
      width="1600"
      height="900"
    />
    <div class="hero-bg-overlay" aria-hidden="true"></div>

    <div class="page-hero-body">
      <nav aria-label="Fil d'Ariane">
        <p class="page-breadcrumb">
          <a href="/">Accueil</a>
          <span aria-hidden="true">→</span>
          <span>La Fabrique</span>
        </p>
      </nav>

      <span class="hero-eyebrow">
        <span class="dot" aria-hidden="true"></span>
        Groupe Holding MG · Depuis 2021
      </span>

      <h1 id="fab-hero-h1" class="page-hero-title">
        <span class="line"><span>LA</span></span>
        <span class="line"><span><em>FABRIQUE.</em></span></span>
      </h1>

      <p class="page-hero-lead">
        Atelier de fabrication & pose de menuiseries extérieures en aluminium.
        Du bureau d'étude à la pose sur site — tout en interne.
      </p>
    </div>
  </section>

  <!-- ████ STATS BAND VERTICALE ████ -->
  <section class="stats-band-v2" aria-label="Chiffres clés">
    <div class="stats-v2-inner">

      <div class="stats-v2-head reveal">
        <span class="s-tag">Identité</span>
        <h2 class="stats-v2-title">EN <em>BREF.</em></h2>
      </div>

      <ul class="stats-v2-list stagger" role="list">

        <li class="stat-line" role="listitem">
          <span class="stat-line-num stat-num-gradient" data-count="2021">2021</span>
          <div class="stat-line-body">
            <span class="stat-line-label">Création</span>
            <span class="stat-line-desc">SAS — Atelier de fabrication & pose de menuiseries aluminium</span>
          </div>
        </li>

        <li class="stat-line" role="listitem">
          <span class="stat-line-num stat-num-gradient">FOM</span>
          <div class="stat-line-body">
            <span class="stat-line-label">Machines dernière génération</span>
            <span class="stat-line-desc">Atelier moderne et performant — découpe, usinage, assemblage</span>
          </div>
        </li>

        <li class="stat-line" role="listitem">
          <span class="stat-line-num stat-num-gradient">Reynaers</span>
          <div class="stat-line-body">
            <span class="stat-line-label">Partenaire innovation</span>
            <span class="stat-line-desc">Leader européen — performances thermiques et normatives</span>
          </div>
        </li>

      </ul>
    </div>
  </section>

  <!-- ████ PRÉSENTATION — Light break crème ████ -->
  <section class="about-light" aria-labelledby="fab-pres-h2">
    <div class="about-inner">

      <div class="about-img-wrap reveal-left">
        <img
          src="/images/expertises/menuiserie-et-aluminium.webp"
          alt="Atelier La Fabrique — production de menuiseries aluminium"
          loading="lazy"
          width="800"
          height="600"
        />
        <div class="about-img-badge">Atelier · Bouc-Bel-Air</div>
      </div>

      <div class="about-content reveal">
        <span class="s-tag">L'atelier</span>
        <h2 id="fab-pres-h2" class="about-title">
          PRODUCTION<br/><em>INTÉGRÉE.</em>
        </h2>
        <p>
          Née pour compléter l'activité du Groupe Holding MG, <strong>La Fabrique</strong> est une jeune entreprise dynamique qui bénéficie de la solidité de la maison mère Eurolook Construction. Spécialisée dans la production de menuiseries extérieures en aluminium, elle accompagne les professionnels du bâtiment avec une offre intégrée — du bureau d'étude à la pose sur site.
        </p>
        <p>
          Chaque projet est traité de la conception à l'installation par les mêmes équipes du groupe.
        </p>

        <div class="about-chips">
          <span class="about-chip">SAS 2021</span>
          <span class="about-chip">Machines FOM</span>
          <span class="about-chip">Partenaire Reynaers</span>
          <span class="about-chip">Étude → Pose</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ████ SPÉCIALITÉS — fond sombre ████ -->
  <section class="exp-section" aria-labelledby="fab-spec-h2">
    <div class="exp-inner" style="max-width:1440px;margin:0 auto;padding:0 var(--gap);">

      <div class="s-head-v2 reveal">
        <div>
          <span class="s-tag">Nos spécialités</span>
          <h2 id="fab-spec-h2" class="s-title-v2">
            CE QUE NOUS<br/><em>FABRIQUONS.</em>
          </h2>
        </div>
      </div>

      <div class="exp-grid-cards stagger">

        <article class="exp-card-v2">
          <div class="exp-card-img-v2">
            <img src="/images/expertises/menuiserie-et-aluminium.webp" alt="Murs rideaux aluminium" loading="lazy" width="800" height="480" />
            <div class="exp-card-num">01</div>
          </div>
          <div class="exp-card-body-v2">
            <span class="exp-card-tag">Façades grande envergure</span>
            <h3 class="exp-card-title-v2">Murs rideaux</h3>
            <p class="exp-card-desc-v2">
              Façades aluminium de grande envergure : calcul thermique, fabrication sur mesure et pose par nos équipes intégrées.
            </p>
          </div>
        </article>

        <article class="exp-card-v2">
          <div class="exp-card-img-v2">
            <img src="/images/expertises/rehabilitation-technique.webp" alt="Portes pare-balle et coupe-feu" loading="lazy" width="800" height="480" />
            <div class="exp-card-num">02</div>
          </div>
          <div class="exp-card-body-v2">
            <span class="exp-card-tag">Sécurité renforcée</span>
            <h3 class="exp-card-title-v2">Portes pare-balle & coupe-feu</h3>
            <p class="exp-card-desc-v2">
              Conception et fabrication de portes répondant aux exigences de sécurité — résistance balistique et tenue au feu.
            </p>
          </div>
        </article>

        <article class="exp-card-v2">
          <div class="exp-card-img-v2">
            <img src="/images/la-fabrique-hero.webp" alt="Portes à pivots déportés" loading="lazy" width="800" height="480" />
            <div class="exp-card-num">03</div>
          </div>
          <div class="exp-card-body-v2">
            <span class="exp-card-tag">Haut de gamme</span>
            <h3 class="exp-card-title-v2">Portes à pivots déportés</h3>
            <p class="exp-card-desc-v2">
              Solutions haut de gamme pour architectes : pivots déportés, grandes dimensions, finitions sur mesure.
            </p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ████ ORGANISATION INTERNE — fond noir ████ -->
  <section class="org-section-v2" aria-labelledby="fab-org-h2">
    <div class="org-inner-v2">
      <div class="s-head-v2 reveal">
        <div>
          <span class="s-tag">L'équipe</span>
          <h2 id="fab-org-h2" class="s-title-v2">
            TROIS<br/><em>BRANCHES.</em>
          </h2>
        </div>
      </div>

      <div class="org-grid-v2 stagger">
        <article class="org-card-v2">
          <span class="org-icon-v2" aria-hidden="true">📋</span>
          <h3>Administratif</h3>
          <p>Direction générale, responsable administrative et financière — gestion rigoureuse de tous les projets.</p>
        </article>
        <article class="org-card-v2">
          <span class="org-icon-v2" aria-hidden="true">📞</span>
          <h3>Commercial</h3>
          <p>Suivi client, devis, négociation. Interface dédiée pour chaque professionnel du bâtiment.</p>
        </article>
        <article class="org-card-v2">
          <span class="org-icon-v2" aria-hidden="true">📐</span>
          <h3>Technique</h3>
          <p>Chargé d'affaire et ingénieur d'étude. Faisabilité, optimisation production, anticipation des contraintes de pose.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ████ PROJETS DE RÉFÉRENCE — fond sombre ████ -->
  <section class="exp-section" style="background:var(--black2);" aria-labelledby="fab-proj-h2">
    <div class="exp-inner" style="max-width:1440px;margin:0 auto;padding:0 var(--gap);">

      <div class="s-head-v2 reveal">
        <div>
          <span class="s-tag">Projets de référence</span>
          <h2 id="fab-proj-h2" class="s-title-v2">
            RÉALISATIONS<br/><em>MARQUANTES.</em>
          </h2>
        </div>
      </div>

      <div class="exp-grid-cards stagger" style="grid-template-columns:1fr;gap:1.5rem;">

        <article class="exp-card-v2 fab-projet-card">
          <div class="exp-card-img-v2">
            <img src="/images/expertises/menuiserie-et-aluminium.webp" alt="EHPAD 98 logements — Maule" loading="lazy" width="800" height="480" />
          </div>
          <div class="exp-card-body-v2">
            <span class="exp-card-tag">Eiffage Construction (78)</span>
            <h3 class="exp-card-title-v2">EHPAD — 98 logements</h3>
            <p class="exp-card-desc-v2">
              Fourniture et pose de murs-rideaux et menuiseries extérieures aluminium pour un EHPAD de 98 logements. Maule (78).
            </p>
            <div class="fab-projet-meta">
              <span class="fab-projet-montant">255 000 € HT</span>
            </div>
          </div>
        </article>

        <article class="exp-card-v2 fab-projet-card">
          <div class="exp-card-img-v2">
            <img src="/images/la-fabrique-hero.webp" alt="Fief de San Gregorio — Mugnano, Italie" loading="lazy" width="800" height="480" />
          </div>
          <div class="exp-card-body-v2">
            <span class="exp-card-tag">Arteco SRL · Italie</span>
            <h3 class="exp-card-title-v2">Fief de San Gregorio</h3>
            <p class="exp-card-desc-v2">
              Fourniture et pose de menuiseries extérieures sur un programme à l'international. Mugnano, Italie.
            </p>
            <div class="fab-projet-meta">
              <span class="fab-projet-montant">1 200 000 € HT</span>
            </div>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ████ LE GROUPE — Light break ████ -->
  <section class="about-light" aria-labelledby="fab-groupe-h2">
    <div class="about-inner">

      <div class="about-content reveal">
        <span class="s-tag">Holding MG</span>
        <h2 id="fab-groupe-h2" class="about-title">
          DEUX ENTITÉS,<br/><em>UN GROUPE.</em>
        </h2>
        <p>
          La Fabrique est l'une des deux entités opérationnelles du Groupe Holding MG, aux côtés d'<strong>Eurolook Construction</strong>. Cette complémentarité permet au groupe de proposer une offre intégrée : gros-œuvre, second-œuvre, renforcement structurel <em>et</em> menuiseries aluminium — le tout sous la supervision d'un responsable QSSE commun et d'une politique sécurité unifiée.
        </p>

        <div class="about-chips">
          <span class="about-chip">Holding MG</span>
          <span class="about-chip">QSSE unifié</span>
          <span class="about-chip">Sécurité commune</span>
        </div>

        <a href="/entreprise" class="about-link">
          Découvrir le groupe
          <svg width="20" height="12" viewBox="0 0 20 12" fill="none" aria-hidden="true">
            <path d="M14 1L19 6L14 11M19 6H1" stroke="currentColor" stroke-width="2"/>
          </svg>
        </a>
      </div>

      <div class="reveal-right" style="display:flex;flex-direction:column;gap:1.25rem;">
        <div class="fab-entity-card">
          <span class="fab-entity-type">SARL</span>
          <span class="fab-entity-name">Eurolook Construction</span>
          <span class="fab-entity-year">Créée en 2015</span>
          <span class="fab-entity-desc">Entreprise générale du bâtiment</span>
        </div>
        <div class="fab-entity-card fab-entity-card--active">
          <span class="fab-entity-type">SAS</span>
          <span class="fab-entity-name">La Fabrique</span>
          <span class="fab-entity-year">Créée en 2021</span>
          <span class="fab-entity-desc">Fabrication & pose de menuiseries aluminium</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ████ CTA FINALE ████ -->
  <section class="cta-band-v2" aria-labelledby="fab-cta-h2">
    <div class="cta-band-v2-inner reveal">
      <h2 id="fab-cta-h2">UN PROJET DE<br/><em>MENUISERIE</em> ALUMINIUM ?</h2>
      <div>
        <p>Bureau d'étude intégré, fabrication et pose en interne — pour les projets les plus exigeants.</p>
        <br>
        <a href="/contact" class="btn btn-dark">Demander un devis</a>
      </div>
    </div>
  </section>

</Layout>
