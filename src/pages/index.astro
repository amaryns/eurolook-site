---
// src/pages/index.astro
// Homepage Eurolook Construction — VERSION 2.0
// Refonte esthétique + corrections factuelles
// La section "Chantiers marquants" est alimentée automatiquement
// depuis src/data/projets.ts (champ enAvant: true)

import Layout from '../layouts/Layout.astro';
import { getProjetsEnAvant } from '../data/projets';

const projetsEnAvant = getProjetsEnAvant(2);
---

<Layout
  title="Eurolook Construction — Renforcement structurel, réhabilitation technique & aménagement commercial"
  description="Entreprise Générale du Bâtiment certifiée MASE depuis 2019. Renforcement structurel, réhabilitation technique et aménagement commercial. Klépierre, Carmila, Carrefour nous font confiance."
  canonical="https://eurolookgroup.com/"
>

  <!-- ████ 1. HERO — Cinématique ████ -->
  <section class="hero" aria-labelledby="hero-h1">
    <img
      class="hero-bg-img"
      src="/images/hero-home.webp"
      alt=""
      role="presentation"
      loading="eager"
      fetchpriority="high"
      width="1600"
      height="900"
    />
    <div class="hero-bg-overlay" aria-hidden="true"></div>

    <div class="hero-body">
      <span class="hero-eyebrow">
        <span class="dot" aria-hidden="true"></span>
        Certification MASE · Depuis 2015
      </span>

      <h1 id="hero-h1" class="hero-title">
        <span class="line"><span>NOUS</span></span>
        <span class="line"><span>BÂTISSONS</span></span>
        <span class="line"><span><em>CE QUI DURE.</em></span></span>
      </h1>

      <p class="hero-lead">
        Renforcement structurel, réhabilitation technique et aménagement commercial.
        Klépierre, Carmila, Carrefour nous font confiance.
      </p>

      <div class="hero-actions">
        <a class="btn btn-gold-v2" href="/realisations">Voir nos chantiers</a>
        <a class="btn btn-outline-light" href="/contact">Devis gratuit</a>
      </div>

      <div class="hero-scroll" aria-hidden="true">
        <span class="hero-scroll-label">Découvrir</span>
        <span class="hero-scroll-line"></span>
      </div>
    </div>
  </section>

  <!-- ████ 2. STATS BAND — Format éditorial vertical ████ -->
  <section class="stats-band-v2" aria-label="Chiffres clés">
    <div class="stats-v2-inner">

      <div class="stats-v2-head reveal">
        <span class="s-tag">Repères</span>
        <h2 class="stats-v2-title">EN <em>BREF.</em></h2>
      </div>

      <ul class="stats-v2-list stagger" role="list">

        <li class="stat-line" role="listitem">
          <span class="stat-line-num stat-num-gradient" data-count="2015">2015</span>
          <div class="stat-line-body">
            <span class="stat-line-label">Création d'Euro Look</span>
            <span class="stat-line-desc">Entreprise Générale du Bâtiment — Holding MG</span>
          </div>
        </li>

        <li class="stat-line" role="listitem">
          <span class="stat-line-num stat-num-gradient" data-count="2019">2019</span>
          <div class="stat-line-body">
            <span class="stat-line-label">Certification MASE</span>
            <span class="stat-line-desc">Qualité, santé, sécurité, environnement — objectif Zéro Accident</span>
          </div>
        </li>

        <li class="stat-line" role="listitem">
          <span class="stat-line-num stat-num-gradient" data-count="2021">2021</span>
          <div class="stat-line-body">
            <span class="stat-line-label">Création de La Fabrique</span>
            <span class="stat-line-desc">Atelier de menuiseries aluminium — Partenaire Reynaers</span>
          </div>
        </li>

      </ul>
    </div>
  </section>

  <!-- ████ 3. L'ENTREPRISE — Light break crème ████ -->
  <section id="entreprise" class="about-light" aria-labelledby="about-h2">
    <div class="about-inner">

      <div class="about-img-wrap reveal-left">
        <img
          src="/images/about-equipe.webp"
          alt="Équipe Eurolook Construction en action sur chantier"
          loading="lazy"
          width="800"
          height="600"
        />
        <div class="about-img-badge">Holding MG · Depuis 2015</div>
      </div>

      <div class="about-content reveal">
        <span class="s-tag">L'entreprise</span>
        <h2 id="about-h2" class="about-title">
          BÂTISSEURS<br/><em>DEPUIS 2015.</em>
        </h2>
        <p>
          Fondée en 2015, Eurolook Construction est une Entreprise Générale du Bâtiment spécialisée dans la rénovation de magasins en centres commerciaux et le renforcement structurel. Référencée auprès de Carrefour, Carmila et Klépierre.
        </p>
        <p>
          Depuis l'obtention de la certification MASE en 2019, l'entreprise s'est ouverte à de nouveaux marchés — dont la pétrochimie — en garantissant un système de management fondé sur la qualité, la santé, la sécurité et l'environnement.
        </p>

        <div class="about-chips">
          <span class="about-chip">Création 2015</span>
          <span class="about-chip">MASE 2019</span>
          <span class="about-chip">Partenaire ISER</span>
          <span class="about-chip">50% CA Renforcement</span>
        </div>

        <a href="/entreprise" class="about-link">
          Découvrir l'entreprise
          <svg width="20" height="12" viewBox="0 0 20 12" fill="none" aria-hidden="true">
            <path d="M14 1L19 6L14 11M19 6H1" stroke="currentColor" stroke-width="2"/>
          </svg>
        </a>
      </div>

    </div>
  </section>

  <!-- ████ 4. EXPERTISES — Cards modernes ████ -->
  <section class="exp-section" aria-labelledby="exp-h2">
    <div class="exp-inner" style="max-width:1440px;margin:0 auto;padding:0 var(--gap);">

      <div class="s-head-v2 reveal">
        <div>
          <span class="s-tag">Nos expertises</span>
          <h2 id="exp-h2" class="s-title-v2">
            CE QUE NOUS<br/><em>FAISONS.</em>
          </h2>
        </div>
        <a href="/expertises" class="see-all">
          Toutes nos expertises
          <svg width="18" height="10" viewBox="0 0 18 10" fill="none" aria-hidden="true">
            <path d="M13 1L17 5L13 9M17 5H1" stroke="currentColor" stroke-width="2"/>
          </svg>
        </a>
      </div>

      <div class="exp-grid-cards stagger">

        <article class="exp-card-v2">
          <div class="exp-card-img-v2">
            <img src="/images/expertises/renforcement-structurel.webp" alt="Renforcement structurel — chantier Eurolook" loading="lazy" decoding="async" width="800" height="480" />
            <div class="exp-card-num">01</div>
          </div>
          <div class="exp-card-body-v2">
            <span class="exp-card-tag">Cœur de métier — 50 % CA</span>
            <h3 class="exp-card-title-v2">Renforcement structurel</h3>
            <p class="exp-card-desc-v2">
              Reprise en sous-œuvre, micropieux, injection de résines. En partenariat avec le cabinet ISER.
            </p>
            <a href="/expertises/renforcement-structurel" class="exp-card-link">Découvrir →</a>
          </div>
        </article>

        <article class="exp-card-v2">
          <div class="exp-card-img-v2">
            <img src="/images/expertises/rehabilitation-technique.webp" alt="Réhabilitation technique en site occupé" loading="lazy" decoding="async" width="800" height="480" />
            <div class="exp-card-num">02</div>
          </div>
          <div class="exp-card-body-v2">
            <span class="exp-card-tag">Site occupé</span>
            <h3 class="exp-card-title-v2">Réhabilitation technique</h3>
            <p class="exp-card-desc-v2">
              Centres commerciaux, agences bancaires, sites industriels — sans jamais interrompre l'activité.
            </p>
            <a href="/expertises/rehabilitation-technique" class="exp-card-link">Découvrir →</a>
          </div>
        </article>

        <article class="exp-card-v2">
          <div class="exp-card-img-v2">
            <img src="/images/expertises/conception-amenagement-points-de-vente.webp" alt="Conception et aménagement de points de vente multi-sites" loading="lazy" decoding="async" width="800" height="480" />
            <div class="exp-card-num">03</div>
          </div>
          <div class="exp-card-body-v2">
            <span class="exp-card-tag">Enseignes nationales</span>
            <h3 class="exp-card-title-v2">Conception & aménagement de points de vente</h3>
            <p class="exp-card-desc-v2">
              Déploiement multi-sites : La Barbe de Papa (29 boutiques), Indémodable, Shoozze.
            </p>
            <a href="/expertises/conception-amenagement-points-de-vente" class="exp-card-link">Découvrir →</a>
          </div>
        </article>

        <article class="exp-card-v2">
          <div class="exp-card-img-v2">
            <img src="/images/expertises/menuiserie-et-aluminium.webp" alt="Menuiserie et aluminium — Atelier La Fabrique" loading="lazy" decoding="async" width="800" height="480" />
            <div class="exp-card-num">04</div>
          </div>
          <div class="exp-card-body-v2">
            <span class="exp-card-tag">Atelier La Fabrique</span>
            <h3 class="exp-card-title-v2">Menuiserie et aluminium</h3>
            <p class="exp-card-desc-v2">
              Murs rideaux, portes pare-balle et coupe-feu, pivots déportés. Partenaire Reynaers, machines FOM.
            </p>
            <a href="/expertises/menuiserie-et-aluminium" class="exp-card-link">Découvrir →</a>
          </div>
        </article>

        <article class="exp-card-v2">
          <div class="exp-card-img-v2">
            <img src="/images/expertises/pilotage-coordination-chantier-opc.webp" alt="Pilotage et coordination de chantier OPC — MOE/MOA" loading="lazy" decoding="async" width="800" height="480" />
            <div class="exp-card-num">05</div>
          </div>
          <div class="exp-card-body-v2">
            <span class="exp-card-tag">Pilotage MOE/MOA</span>
            <h3 class="exp-card-title-v2">Pilotage & coordination de chantier (OPC)</h3>
            <p class="exp-card-desc-v2">
              Dessins exécutifs, OPC, suivi de chantier multi-lots jusqu'à la réception.
            </p>
            <a href="/expertises/pilotage-coordination-chantier-opc" class="exp-card-link">Découvrir →</a>
          </div>
        </article>

        <article class="exp-card-v2">
          <div class="exp-card-img-v2">
            <img src="/images/expertises/amenagements-tertiaires-finitions.webp" alt="Aménagements tertiaires et finitions haut de gamme" loading="lazy" decoding="async" width="800" height="480" />
            <div class="exp-card-num">06</div>
          </div>
          <div class="exp-card-body-v2">
            <span class="exp-card-tag">Tertiaire & Commercial</span>
            <h3 class="exp-card-title-v2">Aménagements tertiaires & finitions</h3>
            <p class="exp-card-desc-v2">
              Cloisons, faux plafonds, revêtements, fluides. Finitions haut de gamme.
            </p>
            <a href="/expertises/amenagements-tertiaires-finitions" class="exp-card-link">Découvrir →</a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ████ 5. CTA LIGHT BREAK — entre expertises et réalisations ████ -->
  <section class="cta-light" aria-labelledby="cta-light-h2">
    <div class="cta-light-inner reveal">
      <h2 id="cta-light-h2">UN PROJET DE<br/><em>RENFORCEMENT</em> STRUCTUREL ?</h2>
      <div>
        <p>Notre cœur de métier depuis 2015. Partenariat exclusif avec le cabinet ISER pour les opérations les plus exigeantes.</p>
        <br>
        <a href="/contact" class="btn btn-dark">Demander un devis</a>
      </div>
    </div>
  </section>

  <!-- ████ 6. RÉALISATIONS — Alimenté automatiquement depuis projets.ts ████ -->
  <section id="realisations" class="proj-section" aria-labelledby="proj-h2">
    <div class="exp-inner" style="max-width:1440px;margin:0 auto;padding:0 var(--gap);">

      <div class="s-head-v2 reveal">
        <div>
          <span class="s-tag">Nos réalisations</span>
          <h2 id="proj-h2" class="s-title-v2">
            CHANTIERS<br/><em>MARQUANTS.</em>
          </h2>
        </div>
        <a href="/realisations" class="see-all">
          Tous les projets
          <svg width="18" height="10" viewBox="0 0 18 10" fill="none" aria-hidden="true">
            <path d="M13 1L17 5L13 9M17 5H1" stroke="currentColor" stroke-width="2"/>
          </svg>
        </a>
      </div>

      <div class="proj-grid stagger">
        {projetsEnAvant.map(p => (
          <a
            href={`/realisations/${p.slug}`}
            class="proj-card-link"
            aria-label={`Voir la fiche projet : ${p.titre}`}
          >
            <article class="proj-card" data-cat={p.categorie}>
              <img
                src={p.image}
                alt={p.alt}
                loading="lazy"
                width="800"
                height="500"
              />
              <div class="proj-ov">
                <span class="proj-cat">{p.categorieLabel}</span>
                <h3 class="proj-name">{p.titre}</h3>
                <span class="proj-meta">{p.lieu} · {p.date}</span>
                <p class="proj-desc">{p.resume}</p>
              </div>
            </article>
          </a>
        ))}
      </div>

    </div>

  </section>

  <!-- ████ 7. LA FABRIQUE — Section mini dédiée ████ -->
  <section class="fabrique-band" aria-labelledby="fabrique-h2">
    <div class="fabrique-inner">

      <div class="fabrique-img reveal-left">
        <img
          src="/images/expertises/menuiserie-et-aluminium.webp"
          alt="Atelier La Fabrique — menuiseries aluminium, murs rideaux"
          loading="lazy"
          width="800"
          height="500"
        />
      </div>

      <div class="fabrique-content reveal">
        <span class="s-tag">Filiale du groupe · Depuis 2021</span>
        <h2 id="fabrique-h2" class="fabrique-title">
          LA <em>FABRIQUE.</em>
        </h2>
        <p>
          Atelier de fabrication et pose de menuiseries extérieures en aluminium. Murs rideaux, portes pare-balle et coupe-feu, pivots déportés. Partenaire officiel Reynaers, machines FOM dernière génération.
        </p>
        <a href="/la-fabrique" class="fabrique-link">
          Découvrir La Fabrique
          <svg width="20" height="12" viewBox="0 0 20 12" fill="none" aria-hidden="true">
            <path d="M14 1L19 6L14 11M19 6H1" stroke="currentColor" stroke-width="2"/>
          </svg>
        </a>
      </div>

    </div>
  </section>

  <!-- ████ 8. CARROUSEL CLIENTS — Monochrome ████ -->
  <section class="clients-band" aria-label="Références clients">

    <div class="clients-header">
      <div class="clients-header-left reveal">
        <span class="s-tag">Références</span>
        <h2>ILS NOUS FONT<br/><em>CONFIANCE.</em></h2>
      </div>
      <div class="clients-header-right reveal">
        <strong>6+</strong>
        Enseignes<br/>nationales
      </div>
    </div>

    <div class="carousel-inner" role="region" aria-label="Logos de nos clients" aria-live="off">
      <div class="carousel-track" role="list">
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/klepierre.png" alt="Klépierre" loading="lazy" decoding="async" width="120" height="40" />
        </div>
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/carmila.png" alt="Carmila" loading="lazy" decoding="async" width="120" height="40" />
        </div>
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/leroymerlin.png" alt="Leroy Merlin" loading="lazy" decoding="async" width="120" height="40" />
        </div>
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/carrefour.png" alt="Carrefour" loading="lazy" decoding="async" width="120" height="40" />
        </div>
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/cic.png" alt="CIC" loading="lazy" decoding="async" width="120" height="40" />
        </div>
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/societegenerale.png" alt="Société Générale" loading="lazy" decoding="async" width="120" height="40" />
        </div>
      </div>
    </div>

  </section>

  <!-- ████ 9. ENGAGEMENTS — Bandelette mini ████ -->
  <section class="engagements-v2" aria-labelledby="eng-h2">
    <div class="eng-inner">

      <div class="s-head-v2 reveal">
        <div>
          <span class="s-tag">Nos engagements</span>
          <h2 id="eng-h2" class="s-title-v2">
            CE QUE NOUS<br/><em>GARANTISSONS.</em>
          </h2>
        </div>
      </div>

      <div class="eng-grid stagger">

        <article class="eng-card">
          <span class="eng-icon" aria-hidden="true">🦺</span>
          <h3>Sécurité MASE</h3>
          <p>
            Certifiés MASE depuis 2019, nous appliquons un système de management fondé sur la qualité, la santé, la sécurité et l'environnement. Objectif prioritaire : « Zéro Accident ».
          </p>
        </article>

        <article class="eng-card">
          <span class="eng-icon" aria-hidden="true">🌱</span>
          <h3>Environnement</h3>
          <p>
            Tri sélectif sur tous nos chantiers et dans nos locaux. Réduction active de nos émissions de gaz à effet de serre.
          </p>
        </article>

        <article class="eng-card">
          <span class="eng-icon" aria-hidden="true">🌙</span>
          <h3>Site occupé</h3>
          <p>
            Centres commerciaux, agences bancaires, sites industriels en exploitation : nous intervenons sans interrompre l'activité — y compris en travaux de nuit.
          </p>
        </article>

      </div>
    </div>
  </section>

  <!-- ████ 10. CTA FINALE — Penser plus grand ████ -->
  <section class="cta-band-v2" aria-labelledby="cta-final-h2">
    <div class="cta-band-v2-inner reveal">
      <h2 id="cta-final-h2">PENSER<br/>PLUS <em>GRAND.</em></h2>
      <div>
        <p>Renforcement structurel, réhabilitation, aménagement commercial : confiez-nous votre projet.</p>
        <br>
        <a href="/contact" class="btn btn-dark">Demander un devis</a>
      </div>
    </div>
  </section>

</Layout>
