---
// src/pages/index.astro
// Homepage Eurolook Construction
// La section "Chantiers marquants" est alimentée automatiquement
// depuis src/data/projets.ts (champ enAvant: true)

import Layout from '../layouts/Layout.astro';
import { getProjetsEnAvant } from '../data/projets';

const projetsEnAvant = getProjetsEnAvant(3);
---

<Layout
  title="Eurolook Construction — Renforcement structurel, réhabilitation technique & aménagement commercial"
  description="Eurolook Construction — Expert en renforcement structurel, réhabilitation technique et aménagement commercial. EGB certifié MASE depuis 2015. Klépierre, Carmila, Carrefour nous font confiance."
  canonical="https://eurolookgroup.com/"
>

  <!-- ████ HERO ████ -->
  <section class="hero" aria-labelledby="hero-h1">
    <img
      class="hero-bg"
      src="/images/hero-home.jpg"
      alt=""
      role="presentation"
      loading="eager"
      fetchpriority="high"
      width="1600"
      height="900"
    />
    <div class="hero-body">
      <span class="hero-eyebrow">EGB · Certification MASE · Depuis 2015</span>
      <h1 id="hero-h1" class="hero-title">
        NOUS<br>BÂTISSONS<br><em>CE QUI DURE.</em>
      </h1>
      <p class="hero-lead">Réhabilitation technique, renforcement structurel et aménagement commercial. Klépierre, Carmila, Carrefour nous font confiance depuis 2015.</p>
      <div class="hero-actions">
        <a class="btn btn-gold" href="/realisations">Voir nos chantiers</a>
        <a class="btn btn-outline-light" href="/contact">Devis gratuit</a>
      </div>
      <div class="hero-scroll" aria-hidden="true">
        <span class="hero-scroll-label">Découvrir</span>
        <span class="hero-scroll-line"></span>
      </div>
    </div>
  </section>

  <!-- ████ STATS ████ -->
  <div class="stats-band" role="list" aria-label="Chiffres clés">
    <div class="stat-item" role="listitem">
      <span class="stat-num" data-count="210" data-suffix="+">200+</span>
      <span class="stat-lbl">Projets réalisés</span>
    </div>
    <div class="stat-item" role="listitem">
      <span class="stat-num" data-count="14">14</span>
      <span class="stat-lbl">Années d'expertise</span>
    </div>
    <div class="stat-item" role="listitem">
      <span class="stat-num">MASE</span>
      <span class="stat-lbl">Certifié sécurité</span>
    </div>
    <div class="stat-item" role="listitem">
      <span class="stat-num">48h</span>
      <span class="stat-lbl">Délai de réponse</span>
    </div>
  </div>

  <!-- ████ L'ENTREPRISE ████ -->
  <section id="entreprise" class="about-teaser" aria-labelledby="about-h2">
    <div class="about-teaser-img">
      <img
        src="/images/about-equipe.jpg"
        alt="Équipe Eurolook Construction en action sur chantier"
        loading="lazy"
        width="800"
        height="600"
      />
    </div>
    <div class="about-teaser-body">
      <span class="s-tag">L'entreprise</span>
      <h2 id="about-h2" class="about-teaser-title">BÂTISSEURS DEPUIS 2015</h2>
      <div class="about-teaser-kpis" role="list" aria-label="Chiffres de l'entreprise">
        <div class="about-kpi" role="listitem">
          <span class="about-kpi-num">200+</span>
          <span class="about-kpi-lbl">Projets livrés</span>
        </div>
        <div class="about-kpi" role="listitem">
          <span class="about-kpi-num">3</span>
          <span class="about-kpi-lbl">Corps de métier</span>
        </div>
        <div class="about-kpi" role="listitem">
          <span class="about-kpi-num">MASE</span>
          <span class="about-kpi-lbl">Certifié 2019</span>
        </div>
      </div>
      <p>Fondée en 2015, Eurolook Construction est devenue la référence en réhabilitation technique sur site occupé. Centres commerciaux en activité, tertiaire, industriel — nous intervenons là où d'autres ne peuvent pas.</p>
      <div class="about-chips" role="list">
        <span class="chip" role="listitem">Certification MASE</span>
        <span class="chip" role="listitem">Bureau d'étude intégré</span>
        <span class="chip" role="listitem">Atelier aluminium</span>
        <span class="chip" role="listitem">Site occupé</span>
      </div>
      <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
        <a class="btn btn-navy" href="/entreprise" aria-label="Découvrir l'histoire d'Eurolook Construction">Découvrir l'entreprise</a>
        <a class="btn btn-ghost" href="/contact" aria-label="Demander un devis">Demander un devis</a>
      </div>
    </div>
  </section>

  <!-- ████ CAROUSEL LOGOS CLIENTS ████ -->
  <section class="clients-band" aria-label="Références clients">
    <p class="clients-label" role="heading" aria-level="2">Ils nous font confiance</p>
    <div class="carousel-inner" role="region" aria-label="Logos de nos clients" aria-live="off">
      <div class="carousel-track" role="list">
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/klepierre.png" alt="Klépierre" loading="lazy" width="120" height="40" />
        </div>
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/carmila.png" alt="Carmila" loading="lazy" width="120" height="40" />
        </div>
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/carrefour.png" alt="Carrefour" loading="lazy" width="120" height="40" />
        </div>
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/kemone.png" alt="Kem One" loading="lazy" width="120" height="40" />
        </div>
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/klepierre.png" alt="Klépierre" loading="lazy" width="120" height="40" />
        </div>
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/carmila.png" alt="Carmila" loading="lazy" width="120" height="40" />
        </div>
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/carrefour.png" alt="Carrefour" loading="lazy" width="120" height="40" />
        </div>
        <div class="c-item" role="listitem">
          <img src="/logos/carousel/kemone.png" alt="Kem One" loading="lazy" width="120" height="40" />
        </div>
      </div>
    </div>
  </section>

  <!-- ████ EXPERTISES ████ -->
  <section id="expertises" class="exp-section" aria-labelledby="exp-h2">
    <div class="s-head">
      <div>
        <span class="s-tag">Nos expertises</span>
        <h2 id="exp-h2" class="s-title">CE QUE NOUS FAISONS</h2>
      </div>
      <a class="see-all" href="/expertises">Tout voir →</a>
    </div>

    <div class="exp-tabs-wrap" role="tablist" aria-label="Sélectionner une expertise">
      <!-- Liste des onglets -->
      <div class="exp-tab-list">
        <button class="exp-tab-btn is-active" data-tab="str" aria-selected="true" role="tab">
          <span class="exp-tab-num" aria-hidden="true">01</span>
          <span class="exp-tab-name">Renforcement structurel</span>
          <span class="exp-tab-arrow" aria-hidden="true">▶</span>
        </button>
        <button class="exp-tab-btn" data-tab="renov" aria-selected="false" role="tab">
          <span class="exp-tab-num" aria-hidden="true">02</span>
          <span class="exp-tab-name">Réhabilitation technique</span>
          <span class="exp-tab-arrow" aria-hidden="true">▶</span>
        </button>
        <button class="exp-tab-btn" data-tab="com" aria-selected="false" role="tab">
          <span class="exp-tab-num" aria-hidden="true">03</span>
          <span class="exp-tab-name">Aménagement de commerces</span>
          <span class="exp-tab-arrow" aria-hidden="true">▶</span>
        </button>
        <button class="exp-tab-btn" data-tab="alu" aria-selected="false" role="tab">
          <span class="exp-tab-num" aria-hidden="true">04</span>
          <span class="exp-tab-name">Menuiseries aluminium</span>
          <span class="exp-tab-arrow" aria-hidden="true">▶</span>
        </button>
        <button class="exp-tab-btn" data-tab="coord" aria-selected="false" role="tab">
          <span class="exp-tab-num" aria-hidden="true">05</span>
          <span class="exp-tab-name">Coordination technique</span>
          <span class="exp-tab-arrow" aria-hidden="true">▶</span>
        </button>
        <button class="exp-tab-btn" data-tab="int" aria-selected="false" role="tab">
          <span class="exp-tab-num" aria-hidden="true">06</span>
          <span class="exp-tab-name">Aménagement intérieur</span>
          <span class="exp-tab-arrow" aria-hidden="true">▶</span>
        </button>
      </div>

      <!-- Panneaux -->
      <div class="exp-panel-wrap">

        <div id="panel-str" class="exp-panel is-active" role="tabpanel" style="display:grid">
          <div class="exp-panel-img">
            <img src="/images/expertises/renforcement.jpg" alt="Renforcement structurel — chantier Eurolook" loading="lazy" width="900" height="500" />
          </div>
          <div class="exp-panel-body">
            <span class="exp-panel-badge">★ Cœur de métier</span>
            <h3 class="exp-panel-h3">Renforcement structurel</h3>
            <p class="exp-panel-p">Reprise en sous-œuvre, micropieux, injection de résines, renforcement de dalles et voiles béton. Notre cœur de métier depuis 2015.</p>
            <div class="exp-panel-tags">
              <span class="exp-panel-tag">Micropieux</span>
              <span class="exp-panel-tag">Sous-œuvre</span>
              <span class="exp-panel-tag">Béton armé</span>
              <span class="exp-panel-tag">Bureau Veritas</span>
            </div>
          </div>
        </div>

        <div id="panel-renov" class="exp-panel" role="tabpanel" style="display:none">
          <div class="exp-panel-img">
            <img src="/images/expertises/rehabilitation.jpg" alt="Réhabilitation technique — site occupé" loading="lazy" width="900" height="500" />
          </div>
          <div class="exp-panel-body">
            <span class="exp-panel-badge">Expertise 02</span>
            <h3 class="exp-panel-h3">Réhabilitation technique</h3>
            <p class="exp-panel-p">Intervention en site occupé, de nuit comme en semaine. Centres commerciaux, tertiaire, industriel — sans jamais interrompre l'activité.</p>
            <div class="exp-panel-tags">
              <span class="exp-panel-tag">Site occupé</span>
              <span class="exp-panel-tag">Nuit & week-end</span>
              <span class="exp-panel-tag">Multi-corps</span>
              <span class="exp-panel-tag">Zéro interruption</span>
            </div>
          </div>
        </div>

        <div id="panel-com" class="exp-panel" role="tabpanel" style="display:none">
          <div class="exp-panel-img">
            <img src="/images/expertises/commerces.jpg" alt="Aménagement de commerces — multi-sites" loading="lazy" width="900" height="500" />
          </div>
          <div class="exp-panel-body">
            <span class="exp-panel-badge">Expertise 03</span>
            <h3 class="exp-panel-h3">Aménagement de commerces</h3>
            <p class="exp-panel-p">Déploiement multi-sites pour enseignes nationales. Respect strict des chartes enseigne, délais de réouverture et budgets contractuels.</p>
            <div class="exp-panel-tags">
              <span class="exp-panel-tag">Multi-sites</span>
              <span class="exp-panel-tag">Chartes enseigne</span>
              <span class="exp-panel-tag">Délais garantis</span>
              <span class="exp-panel-tag">Gestion projet</span>
            </div>
          </div>
        </div>

        <div id="panel-alu" class="exp-panel" role="tabpanel" style="display:none">
          <div class="exp-panel-img">
            <img src="/images/expertises/aluminium.jpg" alt="Menuiseries aluminium — Atelier La Fabrique" loading="lazy" width="900" height="500" />
          </div>
          <div class="exp-panel-body">
            <span class="exp-panel-badge">Expertise 04</span>
            <h3 class="exp-panel-h3">Menuiseries aluminium</h3>
            <p class="exp-panel-p">Atelier La Fabrique intégré — fabrication sur mesure de façades rideau, vitrines, verrières et portes automatiques. Tout en interne.</p>
            <div class="exp-panel-tags">
              <span class="exp-panel-tag">Façades rideau</span>
              <span class="exp-panel-tag">Vitrines</span>
              <span class="exp-panel-tag">Verrières</span>
              <span class="exp-panel-tag">Sur mesure</span>
            </div>
          </div>
        </div>

        <div id="panel-coord" class="exp-panel" role="tabpanel" style="display:none">
          <div class="exp-panel-img">
            <img src="/images/expertises/coordination.jpg" alt="Coordination technique — pilotage MOE/MOA" loading="lazy" width="900" height="500" />
          </div>
          <div class="exp-panel-body">
            <span class="exp-panel-badge">Expertise 05</span>
            <h3 class="exp-panel-h3">Coordination technique</h3>
            <p class="exp-panel-p">Pilotage technique de chantier, interface MOE/MOA, plans d'exécution et conformité réglementaire. Coordination jusqu'à réception OPR.</p>
            <div class="exp-panel-tags">
              <span class="exp-panel-tag">MOE/MOA</span>
              <span class="exp-panel-tag">Plans d'exécution</span>
              <span class="exp-panel-tag">OPR</span>
              <span class="exp-panel-tag">Réglementaire</span>
            </div>
          </div>
        </div>

        <div id="panel-int" class="exp-panel" role="tabpanel" style="display:none">
          <div class="exp-panel-img">
            <img src="/images/expertises/interieur.jpg" alt="Aménagement intérieur tertiaire et commercial" loading="lazy" width="900" height="500" />
          </div>
          <div class="exp-panel-body">
            <span class="exp-panel-badge">Expertise 06</span>
            <h3 class="exp-panel-h3">Aménagement intérieur</h3>
            <p class="exp-panel-p">Cloisons, faux plafonds, revêtements sols et murs, fluides. Finitions haut de gamme pour espaces tertiaires et commerciaux.</p>
            <div class="exp-panel-tags">
              <span class="exp-panel-tag">Cloisons</span>
              <span class="exp-panel-tag">Faux plafonds</span>
              <span class="exp-panel-tag">Revêtements</span>
              <span class="exp-panel-tag">Fluides</span>
            </div>
          </div>
        </div>

      </div>
    </div>

    <div class="exp-inline-cta">
      <p>Un projet de <em>renforcement structurel</em>&nbsp;?</p>
      <a class="btn btn-gold" href="/contact">Demander un devis</a>
    </div>
  </section>

  <!-- ████ RÉALISATIONS (aperçu — alimenté automatiquement depuis projets.ts) ████ -->
  <section id="realisations" class="proj-section" aria-labelledby="proj-h2">
    <div class="s-head">
      <div>
        <span class="s-tag">Nos réalisations</span>
        <h2 id="proj-h2" class="s-title">CHANTIERS MARQUANTS</h2>
      </div>
      <a class="see-all" href="/realisations">Tous les projets →</a>
    </div>

    <div class="proj-grid" role="list">
      {projetsEnAvant.map(p => (
        <a
          href={`/realisations/${p.slug}`}
          class="proj-card-link-home"
          role="listitem"
          aria-label={`Voir la fiche projet : ${p.titre}`}
        >
          <article class="proj-card" data-cat={p.categorie}>
            <img src={p.image} alt={p.alt} loading="lazy" width="700" height="480" />
            <div class="proj-ov">
              <span class="proj-cat">{p.categorieLabel}</span>
              <h3 class="proj-name">{p.titre}</h3>
              <span class="proj-meta">{p.lieu} · {p.date}</span>
              <p class="proj-desc">{p.resume}</p>
            </div>
          </article>
        </a>
      ))}
    </div>

    <div class="proj-cta-bar">
      <span>Votre chantier pourrait être le suivant</span>
      <a class="btn btn-navy" href="/contact">Obtenir un devis gratuit</a>
    </div>
  </section>

  <!-- ████ ENGAGEMENTS ████ -->
  <section id="engagements" class="engagements" aria-labelledby="eng-h2">
    <div class="s-head" style="--s-rule:rgba(249,245,238,.15);">
      <div>
        <span class="s-tag">Nos engagements</span>
        <h2 id="eng-h2" class="s-title" style="color:var(--cream);">NOS ENGAGEMENTS</h2>
      </div>
    </div>
    <div class="eng-grid" role="list">
      <div class="eng-card" role="listitem">
        <span class="eng-icon" aria-hidden="true">🦺</span>
        <h3>Sécurité avant tout</h3>
        <p>Certification MASE, protocoles renforcés en zone ATEX, formation permanente. Zéro accident grave depuis 2015.</p>
      </div>
      <div class="eng-card" role="listitem">
        <span class="eng-icon" aria-hidden="true">⏱</span>
        <h3>Respect des délais</h3>
        <p>Chantiers contractuellement encadrés. Chaque retard engage notre responsabilité — c'est notre garantie.</p>
      </div>
      <div class="eng-card" role="listitem">
        <span class="eng-icon" aria-hidden="true">🌱</span>
        <h3>Responsabilité environnementale</h3>
        <p>Gestion rigoureuse des déchets, réemploi des matériaux, bilan carbone suivi sur chaque projet.</p>
      </div>
      <div class="eng-card" role="listitem">
        <span class="eng-icon" aria-hidden="true">🤝</span>
        <h3>Transparence totale</h3>
        <p>Compte-rendu hebdomadaire, journal de chantier partagé. Un seul interlocuteur du devis à la réception.</p>
      </div>
    </div>
  </section>

  <!-- ████ CTA BAND ████ -->
  <section class="cta-band" id="contact" aria-labelledby="cta-h2">
    <div>
      <h2 id="cta-h2">UN PROJET<br>À NOUS<br><em>CONFIER&nbsp;?</em></h2>
      <p>Devis personnalisé sous 48&nbsp;heures, sans engagement. Un interlocuteur unique du premier échange à la livraison.</p>
    </div>
    <a class="btn btn-navy" href="/contact" aria-label="Demander un devis gratuit">Demander un devis</a>
  </section>

</Layout>

<style>
  /* Cards Réalisations sur la homepage — wrapper cliquable */
  .proj-card-link-home {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform .3s ease;
  }
  .proj-card-link-home:hover {
    transform: translateY(-4px);
  }
  .proj-card-link-home:focus-visible {
    outline: 3px solid #B8934A;
    outline-offset: 4px;
    border-radius: 2px;
  }
</style>
