  <!-- ████ CTA FINALE ████ -->
  <section class="cta-band-v2" aria-labelledby="legal-cta-h2">
    <div class="cta-band-v2-inner reveal">
      <h2 id="legal-cta-h2">UNE QUESTION<br/><em>JURIDIQUE ?</em></h2>
      <div>
