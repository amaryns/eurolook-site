---
// src/pages/expertises/index.astro
// ═══════════════════════════════════════════════════════════════════════════
// PAGE HUB EXPERTISES — Liste toutes les expertises (overview)
// Alimentée automatiquement depuis src/data/expertises.ts
// ═══════════════════════════════════════════════════════════════════════════

import Layout from '../../layouts/Layout.astro';
import { getToutesLesExpertises } from '../../data/expertises';

const expertises = getToutesLesExpertises();
---

<Layout
  title="Nos expertises — Eurolook Construction | 6 savoir-faire complémentaires"
  description="Découvrez les 6 expertises d'Eurolook Construction : renforcement structurel, réhabilitation technique, aménagement de commerces, menuiserie aluminium, coordination technique et aménagement intérieur."
  canonical="https://eurolookgroup.com/expertises"
>

  <article class="exp-hub" aria-labelledby="hub-title">

    <!-- ████ HERO ████ -->
    <header class="hub-header">
      <div class="hub-header-inner">
        <nav aria-label="Fil d'Ariane">
          <p class="breadcrumb">
            <a href="/" style="color:inherit;text-decoration:none;">Accueil</a>
            &nbsp;→&nbsp; Expertises
          </p>
        </nav>
        <span class="hub-eyebrow">Nos savoir-faire</span>
        <h1 id="hub-title" class="hub-title">NOS<br>EXPERTISES</h1>
        <p class="hub-intro">
          Six expertises complémentaires structurent l'activité d'Eurolook Construction, du renforcement structurel au déploiement multi-sites pour les enseignes nationales. Chaque savoir-faire est porté par des équipes spécialisées et par notre certification MASE.
        </p>
      </div>
    </header>

    <!-- ████ BANDEAU APPROCHE ████ -->
    <div class="hub-approche" role="list" aria-label="Chiffres clés des expertises">
      <div class="hub-approche-item" role="listitem">
        <span class="hub-approche-v">6</span>
        <span class="hub-approche-l">Expertises</span>
      </div>
      <div class="hub-approche-item" role="listitem">
        <span class="hub-approche-v">200+</span>
        <span class="hub-approche-l">Projets livrés</span>
      </div>
      <div class="hub-approche-item" role="listitem">
        <span class="hub-approche-v">2015</span>
        <span class="hub-approche-l">Depuis</span>
      </div>
      <div class="hub-approche-item" role="listitem">
        <span class="hub-approche-v">MASE</span>
        <span class="hub-approche-l">Certifié 2019</span>
      </div>
    </div>

    <!-- ████ GRILLE EXPERTISES ████ -->
    <section class="hub-grid-section" aria-labelledby="grid-title">
      <h2 id="grid-title" class="visually-hidden">Liste des expertises</h2>
      <div class="hub-grid" role="list">
        {expertises.map(expertise => (
          <a
            href={`/expertises/${expertise.slug}`}
            class="hub-card"
            role="listitem"
            aria-label={`Découvrir l'expertise : ${expertise.titre}`}
          >
            <div class="hub-card-num">{expertise.numero}</div>
            <div class="hub-card-body">
              <h3 class="hub-card-titre">{expertise.titreLong}</h3>
              <p class="hub-card-tagline">{expertise.tagline}</p>
              <p class="hub-card-intro">{expertise.introduction[0]}</p>
              <span class="hub-card-link" aria-hidden="true">
                Découvrir l'expertise <span class="hub-card-arrow">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ████ CTA FINAL ████ -->
    <aside class="hub-cta" aria-labelledby="cta-h2">
      <div class="hub-cta-inner">
        <div class="hub-cta-text">
          <h2 id="cta-h2" class="hub-cta-title">UNE EXPERTISE<br><em>SUR MESURE&nbsp;?</em></h2>
          <p>Devis personnalisé sous 48&nbsp;heures, sans engagement. Un interlocuteur unique du premier échange à la livraison.</p>
        </div>
        <a href="/contact" class="btn-gold-hub" aria-label="Demander un devis gratuit">Demander un devis</a>
      </div>
    </aside>

  </article>

</Layout>

<style>
  .exp-hub{font-family:'Barlow',sans-serif;background:#0C0B09;color:#F9F5EE;}
  .visually-hidden{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;}

  /* ════ HERO ════ */
  .hub-header{position:relative;padding:clamp(3rem,7vw,6rem) 0 clamp(2.5rem,5vw,4rem);background:linear-gradient(135deg,#182338 0%,#0C0B09 70%);overflow:hidden;}
  .hub-header::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 80% 30%,rgba(184,147,74,.12) 0%,transparent 55%);pointer-events:none;}
  .hub-header-inner{position:relative;z-index:2;max-width:1280px;margin:0 auto;padding:0 clamp(1.25rem,4vw,3rem);}
  .breadcrumb{font-family:'Barlow Condensed',sans-serif;font-size:.8125rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:rgba(249,245,238,.5);margin-bottom:1.75rem;}
  .hub-eyebrow{display:inline-flex;align-items:center;gap:.625rem;font-family:'Barlow Condensed',sans-serif;font-size:.875rem;font-weight:700;letter-spacing:.32em;text-transform:uppercase;color:#B8934A;margin-bottom:1.25rem;}
  .hub-eyebrow::before{content:'';display:block;width:32px;height:2px;background:#B8934A;}
  .hub-title{font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,7vw,5.5rem);font-weight:800;letter-spacing:.02em;text-transform:uppercase;color:#F9F5EE;line-height:.95;margin-bottom:1.75rem;}
  .hub-intro{font-size:clamp(1rem,1.4vw,1.1875rem);color:rgba(249,245,238,.78);max-width:780px;margin:0;line-height:1.75;}

  /* ════ BANDEAU APPROCHE ════ */
  .hub-approche{display:grid;grid-template-columns:repeat(4,1fr);max-width:1280px;margin:0 auto;background:#182338;border-bottom:3px solid #B8934A;}
  .hub-approche-item{padding:1.75rem 1rem;text-align:center;border-right:1px solid rgba(184,147,74,.15);}
  .hub-approche-item:last-child{border-right:none;}
  .hub-approche-v{display:block;font-family:'Barlow Condensed',sans-serif;font-size:clamp(1.5rem,2vw,2rem);font-weight:800;color:#DFC08A;letter-spacing:.04em;text-transform:uppercase;line-height:1.1;margin-bottom:.4rem;}
  .hub-approche-l{display:block;font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:rgba(249,245,238,.65);}

  /* ════ GRILLE EXPERTISES ════ */
  .hub-grid-section{max-width:1280px;margin:0 auto;padding:clamp(3rem,6vw,5rem) clamp(1.25rem,4vw,3rem);}
  .hub-grid{display:grid;grid-template-columns:1fr;gap:1.25rem;}

  /* ════ CARD ════ */
  .hub-card{
    display:grid;
    grid-template-columns:auto 1fr;
    gap:clamp(1.25rem,3vw,2.25rem);
    align-items:start;
    background:#151310;
    border:1px solid rgba(184,147,74,.12);
    border-left:4px solid #B8934A;
    border-radius:3px;
    padding:clamp(1.75rem,3vw,2.5rem);
    text-decoration:none;
    color:inherit;
    transition:all .3s ease;
    position:relative;
    overflow:hidden;
  }
  .hub-card::after{
    content:'';
    position:absolute;
    top:0;right:0;bottom:0;
    width:0;
    background:linear-gradient(to left,rgba(184,147,74,.04),transparent);
    transition:width .35s ease;
    pointer-events:none;
  }
  .hub-card:hover{
    background:#1C1A16;
    border-color:rgba(184,147,74,.4);
    border-left-color:#DFC08A;
    transform:translateY(-3px);
  }
  .hub-card:hover::after{width:100%;}
  .hub-card:focus-visible{
    outline:3px solid #B8934A;
    outline-offset:3px;
  }

  .hub-card-num{
    font-family:'Barlow Condensed',sans-serif;
    font-size:clamp(2.5rem,4.5vw,3.75rem);
    font-weight:800;
    color:#B8934A;
    letter-spacing:.04em;
    line-height:1;
    transition:color .3s ease;
  }
  .hub-card:hover .hub-card-num{color:#DFC08A;}

  .hub-card-body{position:relative;z-index:1;}
  .hub-card-titre{
    font-family:'Barlow Condensed',sans-serif;
    font-size:clamp(1.25rem,2vw,1.625rem);
    font-weight:800;
    letter-spacing:.04em;
    text-transform:uppercase;
    color:#F9F5EE;
    margin:0 0 .625rem 0;
    line-height:1.15;
  }
  .hub-card-tagline{
    font-family:'Barlow Condensed',sans-serif;
    font-size:.875rem;
    font-weight:600;
    letter-spacing:.08em;
    text-transform:uppercase;
    color:#DFC08A;
    margin:0 0 1rem 0;
  }
  .hub-card-intro{
    font-size:.9375rem;
    color:rgba(249,245,238,.72);
    margin:0 0 1.5rem 0;
    line-height:1.7;
  }
  .hub-card-link{
    display:inline-flex;
    align-items:center;
    gap:.5rem;
    font-family:'Barlow Condensed',sans-serif;
    font-size:.875rem;
    font-weight:700;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:#B8934A;
    transition:gap .3s ease;
  }
  .hub-card-arrow{transition:transform .3s ease;display:inline-block;}
  .hub-card:hover .hub-card-link{color:#DFC08A;}
  .hub-card:hover .hub-card-arrow{transform:translateX(4px);}

  /* ════ CTA FINAL ════ */
  .hub-cta{background:#182338;border-top:3px solid #B8934A;border-bottom:1px solid rgba(184,147,74,.18);}
  .hub-cta-inner{
    max-width:1280px;
    margin:0 auto;
    padding:clamp(3rem,5vw,4.5rem) clamp(1.25rem,4vw,3rem);
    display:flex;
    align-items:center;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:2rem;
  }
  .hub-cta-text{max-width:560px;}
  .hub-cta-title{
    font-family:'Barlow Condensed',sans-serif;
    font-size:clamp(1.75rem,3.5vw,2.625rem);
    font-weight:800;
    letter-spacing:.03em;
    text-transform:uppercase;
    color:#F9F5EE;
    margin:0 0 1rem 0;
    line-height:1.05;
  }
  .hub-cta-title em{font-style:normal;color:#B8934A;}
  .hub-cta-text p{
    font-size:1.0625rem;
    color:rgba(249,245,238,.78);
    margin:0;
    line-height:1.7;
  }
  .btn-gold-hub{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    background:#B8934A;
    color:#0C0B09;
    font-family:'Barlow Condensed',sans-serif;
    font-size:1rem;
    font-weight:700;
    letter-spacing:.12em;
    text-transform:uppercase;
    padding:1.125rem 2.5rem;
    border:none;
    border-radius:2px;
    cursor:pointer;
    text-decoration:none;
    transition:background .2s,transform .2s;
  }
  .btn-gold-hub:hover{background:#CCA96A;transform:translateY(-2px);}

  /* ════ RESPONSIVE ════ */
  @media (min-width: 768px) {
    .hub-grid{grid-template-columns:1fr 1fr;gap:1.5rem;}
  }
  @media (min-width: 1280px) {
    .hub-grid{gap:1.75rem;}
  }
  @media (max-width: 639px) {
    .hub-approche{grid-template-columns:repeat(2,1fr);}
    .hub-approche-item{border-bottom:1px solid rgba(184,147,74,.15);padding:1.25rem .75rem;}
    .hub-approche-item:nth-child(2n){border-right:none;}
    .hub-approche-item:nth-last-child(-n+2){border-bottom:none;}
    .hub-card{grid-template-columns:1fr;gap:1rem;}
    .hub-card-num{font-size:2.5rem;}
    .hub-cta-inner{flex-direction:column;align-items:flex-start;text-align:left;}
    .btn-gold-hub{width:100%;}
  }
</style>
