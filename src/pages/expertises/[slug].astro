---
// src/pages/expertises/[slug].astro
// ═══════════════════════════════════════════════════════════════════════════
// TEMPLATE DYNAMIQUE — Génère automatiquement les 6 pages expertises
// depuis src/data/expertises.ts
// ═══════════════════════════════════════════════════════════════════════════

import Layout from '../../layouts/Layout.astro';
import { getToutesLesExpertises, getExpertisesSauf } from '../../data/expertises';

// Astro génère une page par expertise (statique au build)
export async function getStaticPaths() {
  const expertises = getToutesLesExpertises();
  return expertises.map(expertise => ({
    params: { slug: expertise.slug },
    props: { expertise },
  }));
}

const { expertise } = Astro.props;
const autresExpertises = getExpertisesSauf(expertise.slug);
---

<Layout
  title={expertise.meta.title}
  description={expertise.meta.description}
  canonical={`https://eurolookgroup.com/expertises/${expertise.slug}`}
>

  <article class="exp" aria-labelledby="exp-title">

    <!-- HERO -->
    <header class="exp-hero">
      <div class="exp-hero-bg" aria-hidden="true"></div>
      <div class="exp-hero-ov" aria-hidden="true"></div>
      <div class="exp-hero-body">
        <div class="exp-hero-inner">
          <nav aria-label="Fil d'Ariane">
            <p class="breadcrumb">
              <a href="/" style="color:inherit;text-decoration:none;">Accueil</a>
              &nbsp;→&nbsp;
              <a href="/expertises" style="color:inherit;text-decoration:none;">Expertises</a>
              &nbsp;→&nbsp; {expertise.titre}
            </p>
          </nav>
          <div class="exp-numero">EXPERTISE {expertise.numero}</div>
          <h1 id="exp-title" class="exp-title">{expertise.titreLong}</h1>
          <p class="exp-tagline">{expertise.tagline}</p>
        </div>
      </div>
    </header>

    <!-- BANDEAU KPIs / VALEUR AJOUTÉE -->
    <div class="exp-kpis-wrap">
      <div class="exp-kpis" role="list" aria-label="Chiffres clés">
        {expertise.valeurAjoutee.map(kpi => (
          <div class="exp-kpi" role="listitem">
            <span class="exp-kpi-l">{kpi.label}</span>
            <span class="exp-kpi-v">{kpi.value}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="exp-content">

      <!-- PRÉSENTATION -->
      <section class="exp-section" aria-labelledby="exp-intro">
        <h2 id="exp-intro" class="exp-h2">Présentation</h2>
        <div class="exp-body">
          {expertise.introduction.map(paragraphe => <p>{paragraphe}</p>)}
        </div>
      </section>

      <!-- MÉTHODOLOGIE -->
      <section class="exp-section" aria-labelledby="exp-method">
        <h2 id="exp-method" class="exp-h2">Méthodologie & approche</h2>
        <div class="exp-body">
          {expertise.methodologie.map(paragraphe => <p>{paragraphe}</p>)}
        </div>
      </section>

      <!-- TYPES D'INTERVENTIONS -->
      <section class="exp-section" aria-labelledby="exp-interventions">
        <h2 id="exp-interventions" class="exp-h2">Types d'interventions</h2>
        <ul class="exp-interventions">
          {expertise.interventions.map(item => (
            <li class="exp-intervention">{item}</li>
          ))}
        </ul>
      </section>

      <!-- LA FABRIQUE (uniquement pour Menuiserie aluminium) -->
      {expertise.laFabrique && (
        <section class="exp-section exp-section-fabrique" aria-labelledby="exp-fabrique">
          <h2 id="exp-fabrique" class="exp-h2">L'Atelier La Fabrique</h2>
          <div class="exp-fabrique-card">
            <div class="exp-fabrique-tag">PARTENAIRE DU GROUPE</div>
            <div class="exp-body">
              {expertise.laFabrique.presentation.map(paragraphe => <p>{paragraphe}</p>)}
            </div>
            <div class="exp-fabrique-details">
              <div class="exp-fabrique-block">
                <h3>Spécialités</h3>
                <ul>
                  {expertise.laFabrique.specialites.map(item => <li>{item}</li>)}
                </ul>
              </div>
              <div class="exp-fabrique-block">
                <h3>Équipement</h3>
                <p>{expertise.laFabrique.equipement}</p>
                <h3 style="margin-top:1.25rem;">Partenaire innovation</h3>
                <p>{expertise.laFabrique.partenaireInnovation}</p>
              </div>
              <div class="exp-fabrique-block">
                <h3>Sous-traitance fabrication</h3>
                <ul>
                  {expertise.laFabrique.sousTraitants.map(item => <li>{item}</li>)}
                </ul>
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- PROJETS EXEMPLES -->
      {expertise.projetsExemples.length > 0 && (
        <section class="exp-section" aria-labelledby="exp-projets">
          <h2 id="exp-projets" class="exp-h2">Projets de référence</h2>
          <div class="exp-projets">
            {expertise.projetsExemples.map(projet => (
              <div class="exp-projet">
                <h3 class="exp-projet-titre">{projet.titre}</h3>
                <p class="exp-projet-details">{projet.details}</p>
                <div class="exp-projet-meta">
                  {projet.client && <span class="exp-projet-client">{projet.client}</span>}
                  {projet.montant && <span class="exp-projet-montant">{projet.montant}</span>}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- PARTENAIRES (si présents) -->
      {expertise.partenaires && expertise.partenaires.length > 0 && (
        <section class="exp-section" aria-labelledby="exp-partenaires">
          <h2 id="exp-partenaires" class="exp-h2">Partenaires techniques</h2>
          <div class="exp-partenaires">
            {expertise.partenaires.map(partenaire => (
              <span class="exp-partenaire-chip">{partenaire}</span>
            ))}
          </div>
        </section>
      )}

    </div>

    <!-- CTA -->
    <aside class="exp-cta" aria-label="Demande de devis">
      <div class="exp-cta-inner">
        <p>Un projet de <em>{expertise.titre.toLowerCase()}</em>&nbsp;?</p>
        <a href="/contact" class="btn-gold">Demander un devis</a>
      </div>
    </aside>

    <!-- AUTRES EXPERTISES -->
    <section class="exp-others" aria-labelledby="exp-others-h">
      <div class="exp-others-inner">
        <h2 id="exp-others-h" class="exp-others-title">NOS AUTRES EXPERTISES</h2>
        <div class="exp-others-grid">
          {autresExpertises.map(autre => (
            <a href={`/expertises/${autre.slug}`} class="exp-other-card">
              <span class="exp-other-num">{autre.numero}</span>
              <h3 class="exp-other-titre">{autre.titre}</h3>
              <span class="exp-other-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

  </article>

</Layout>

<style>
  .exp{font-family:'Barlow',sans-serif;background:#0C0B09;color:#F9F5EE;}
  .breadcrumb{font-family:'Barlow Condensed',sans-serif;font-size:.8125rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:rgba(249,245,238,.55);margin-bottom:1.5rem;}

  /* ════ HERO ════ */
  .exp-hero{position:relative;min-height:clamp(360px,55vh,560px);display:flex;align-items:flex-end;overflow:hidden;background:linear-gradient(135deg,#182338 0%,#0C0B09 60%,#151310 100%);}
  .exp-hero-bg{position:absolute;inset:0;background:radial-gradient(circle at 80% 20%,rgba(184,147,74,.15) 0%,transparent 50%);}
  .exp-hero-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(12,11,9,.95) 0%,rgba(12,11,9,.1) 70%);}
  .exp-hero-body{position:relative;z-index:2;width:100%;padding:3rem 0 3.5rem;}
  .exp-hero-inner{max-width:1280px;margin:0 auto;padding:0 clamp(1.25rem,4vw,3rem);}
  .exp-numero{display:inline-flex;align-items:center;gap:.625rem;font-family:'Barlow Condensed',sans-serif;font-size:.875rem;font-weight:700;letter-spacing:.32em;text-transform:uppercase;color:#B8934A;margin-bottom:1.25rem;}
  .exp-numero::before{content:'';display:block;width:32px;height:2px;background:#B8934A;}
  .exp-title{font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.25rem,6.5vw,5rem);font-weight:800;letter-spacing:.02em;text-transform:uppercase;color:#F9F5EE;line-height:.95;margin-bottom:1.25rem;max-width:900px;}
  .exp-tagline{font-size:clamp(1rem,1.5vw,1.25rem);color:rgba(249,245,238,.78);max-width:680px;margin:0;line-height:1.5;}

  /* ════ KPIs ════ */
  .exp-kpis-wrap{background:#182338;border-bottom:3px solid #B8934A;}
  .exp-kpis{display:grid;grid-template-columns:repeat(4,1fr);max-width:1280px;margin:0 auto;}
  .exp-kpi{padding:1.75rem 1rem;text-align:center;border-right:1px solid rgba(184,147,74,.15);}
  .exp-kpi:last-child{border-right:none;}
  .exp-kpi-l{display:block;font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:rgba(249,245,238,.65);margin-bottom:.5rem;}
  .exp-kpi-v{font-family:'Barlow Condensed',sans-serif;font-size:clamp(1.125rem,1.6vw,1.375rem);font-weight:800;color:#DFC08A;letter-spacing:.04em;text-transform:uppercase;line-height:1.1;}

  /* ════ CONTENU ════ */
  .exp-content{max-width:1100px;margin:0 auto;padding:clamp(2.5rem,6vw,5rem) clamp(1.25rem,4vw,3rem);}
  .exp-section{margin-bottom:4rem;}
  .exp-section:last-child{margin-bottom:0;}
  .exp-h2{font-family:'Barlow Condensed',sans-serif;font-size:clamp(1.5rem,2.75vw,2rem);font-weight:800;letter-spacing:.06em;text-transform:uppercase;color:#F9F5EE;border-left:4px solid #B8934A;padding-left:1.25rem;margin-bottom:1.75rem;}
  .exp-body{font-size:1.0625rem;color:rgba(249,245,238,.78);line-height:1.875;max-width:820px;}
  .exp-body p+p{margin-top:1.125rem;}
  .exp-body strong{color:#DFC08A;font-weight:600;}

  /* ════ INTERVENTIONS ════ */
  .exp-interventions{display:grid;grid-template-columns:1fr;gap:.75rem;list-style:none;padding:0;margin:0;}
  .exp-intervention{position:relative;font-size:.9375rem;color:rgba(249,245,238,.85);padding:1.125rem 1.375rem 1.125rem 3rem;background:#151310;border-left:3px solid #B8934A;border-radius:0 3px 3px 0;line-height:1.5;}
  .exp-intervention::before{content:'→';position:absolute;left:1.25rem;top:1.125rem;color:#B8934A;font-weight:700;font-family:'Barlow Condensed',sans-serif;}

  /* ════ LA FABRIQUE ════ */
  .exp-section-fabrique{background:linear-gradient(135deg,#151310 0%,#0C0B09 100%);padding:2.5rem;border-radius:4px;border:1px solid rgba(184,147,74,.18);margin-bottom:4rem;}
  .exp-fabrique-card{position:relative;}
  .exp-fabrique-tag{display:inline-block;font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:#0C0B09;background:#DFC08A;padding:.375rem .875rem;border-radius:2px;margin-bottom:1.5rem;}
  .exp-fabrique-details{display:grid;grid-template-columns:1fr;gap:1.75rem;margin-top:2rem;padding-top:2rem;border-top:1px solid rgba(184,147,74,.15);}
  .exp-fabrique-block h3{font-family:'Barlow Condensed',sans-serif;font-size:.875rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#DFC08A;margin-bottom:.875rem;}
  .exp-fabrique-block p{font-size:.9375rem;color:rgba(249,245,238,.78);line-height:1.6;margin:0;}
  .exp-fabrique-block ul{list-style:none;padding:0;margin:0;}
  .exp-fabrique-block li{font-size:.9375rem;color:rgba(249,245,238,.82);padding:.375rem 0;padding-left:1rem;position:relative;}
  .exp-fabrique-block li::before{content:'';position:absolute;left:0;top:1rem;width:6px;height:1px;background:#B8934A;}

  /* ════ PROJETS EXEMPLES ════ */
  .exp-projets{display:grid;grid-template-columns:1fr;gap:1rem;}
  .exp-projet{background:#151310;border:1px solid rgba(184,147,74,.12);border-radius:3px;padding:1.75rem;border-left:4px solid #B8934A;}
  .exp-projet-titre{font-family:'Barlow Condensed',sans-serif;font-size:1.125rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#F9F5EE;margin-bottom:.75rem;line-height:1.25;}
  .exp-projet-details{font-size:.9375rem;color:rgba(249,245,238,.78);line-height:1.65;margin:0 0 1rem 0;}
  .exp-projet-meta{display:flex;align-items:center;gap:1.25rem;flex-wrap:wrap;padding-top:.875rem;border-top:1px solid rgba(184,147,74,.1);}
  .exp-projet-client{font-family:'Barlow Condensed',sans-serif;font-size:.8125rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:rgba(249,245,238,.55);}
  .exp-projet-montant{font-family:'Barlow Condensed',sans-serif;font-size:.9375rem;font-weight:800;letter-spacing:.04em;text-transform:uppercase;color:#DFC08A;}

  /* ════ PARTENAIRES ════ */
  .exp-partenaires{display:flex;flex-wrap:wrap;gap:.625rem;}
  .exp-partenaire-chip{display:inline-flex;align-items:center;background:#151310;border:1px solid rgba(184,147,74,.25);color:#DFC08A;font-family:'Barlow Condensed',sans-serif;font-size:.875rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;padding:.625rem 1.125rem;border-radius:2px;}

  /* ════ CTA ════ */
  .exp-cta{background:#182338;border-top:3px solid #B8934A;border-bottom:1px solid rgba(184,147,74,.18);}
  .exp-cta-inner{max-width:1280px;margin:0 auto;padding:clamp(2rem,4vw,3.5rem) clamp(1.25rem,4vw,3rem);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;}
  .exp-cta p{font-family:'Barlow Condensed',sans-serif;font-size:clamp(1.125rem,2vw,1.625rem);font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#F9F5EE;margin:0;line-height:1.2;}
  .exp-cta em{font-style:normal;color:#B8934A;}
  .btn-gold{display:inline-flex;align-items:center;justify-content:center;background:#B8934A;color:#0C0B09;font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:1rem 2.25rem;border:none;border-radius:2px;cursor:pointer;text-decoration:none;transition:background .2s;}
  .btn-gold:hover{background:#CCA96A;}

  /* ════ AUTRES EXPERTISES ════ */
  .exp-others{background:#151310;padding:clamp(3rem,5vw,4.5rem) 0;}
  .exp-others-inner{max-width:1280px;margin:0 auto;padding:0 clamp(1.25rem,4vw,3rem);}
  .exp-others-title{font-family:'Barlow Condensed',sans-serif;font-size:clamp(1.5rem,2.5vw,1.875rem);font-weight:800;letter-spacing:.06em;text-transform:uppercase;color:#F9F5EE;margin-bottom:2rem;text-align:center;}
  .exp-others-grid{display:grid;grid-template-columns:1fr;gap:.875rem;}
  .exp-other-card{display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:1.25rem;background:#1C1A16;border:1px solid rgba(184,147,74,.12);border-radius:3px;padding:1.5rem 1.75rem;text-decoration:none;color:inherit;transition:all .25s ease;}
  .exp-other-card:hover{background:#182338;border-color:rgba(184,147,74,.4);transform:translateX(4px);}
  .exp-other-card:focus-visible{outline:3px solid #B8934A;outline-offset:3px;}
  .exp-other-num{font-family:'Barlow Condensed',sans-serif;font-size:1.5rem;font-weight:800;color:#B8934A;letter-spacing:.05em;}
  .exp-other-titre{font-family:'Barlow Condensed',sans-serif;font-size:1.125rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#F9F5EE;margin:0;}
  .exp-other-arrow{font-family:'Barlow Condensed',sans-serif;font-size:1.25rem;font-weight:700;color:#B8934A;transition:transform .25s ease;}
  .exp-other-card:hover .exp-other-arrow{transform:translateX(4px);}

  /* ════ RESPONSIVE ════ */
  @media (min-width: 640px) {
    .exp-interventions{grid-template-columns:1fr 1fr;}
    .exp-projets{grid-template-columns:1fr 1fr;}
  }
  @media (min-width: 1024px) {
    .exp-fabrique-details{grid-template-columns:1fr 1fr 1fr;}
    .exp-others-grid{grid-template-columns:repeat(5,1fr);}
    .exp-other-card{flex-direction:column;text-align:center;grid-template-columns:1fr;gap:.875rem;padding:1.75rem 1.25rem;}
    .exp-other-card:hover{transform:translateY(-4px);}
    .exp-other-arrow{display:none;}
  }
  @media (max-width: 639px) {
    .exp-kpis{grid-template-columns:repeat(2,1fr);}
    .exp-kpi{border-bottom:1px solid rgba(184,147,74,.15);}
    .exp-kpi:nth-child(2n){border-right:none;}
    .exp-kpi:nth-last-child(-n+2){border-bottom:none;}
    .exp-cta-inner{flex-direction:column;align-items:flex-start;}
    .exp-cta-inner .btn-gold{width:100%;}
  }
</style>
